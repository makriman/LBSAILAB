{
  "name": "lbs-ai-lab",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run seo:assets && npm run seo:images && astro check && astro build && npm run seo:sitemap-index",
    "preview": "astro preview",
    "check": "astro check",
    "seo:assets": "node scripts/optimize-images.mjs",
    "seo:audit": "node scripts/audit-seo.mjs",
    "seo:audit:live": "node scripts/audit-live-seo.mjs",
    "seo:logs": "node scripts/analyze-seo-logs.mjs",
    "seo:all": "npm run seo:ci && npm run seo:monitor && npm run seo:audit:live && npm run seo:perf",
    "seo:ci": "npm run build && npm run seo:audit && npm run seo:integrity && npm run seo:startup",
    "seo:crux": "node scripts/audit-crux.mjs",
    "seo:images": "node scripts/generate-og-images.mjs",
    "seo:indexnow": "node scripts/submit-indexnow.mjs",
    "seo:integrity": "node scripts/audit-content-integrity.mjs",
    "seo:lighthouse": "node scripts/audit-lighthouse.mjs",
    "seo:live": "npm run seo:monitor && npm run seo:audit:live",
    "seo:monitor": "node scripts/monitor-seo.mjs",
    "seo:pagespeed": "node scripts/audit-pagespeed.mjs",
    "seo:perf": "node scripts/audit-performance.mjs",
    "seo:production": "npm run seo:live && npm run seo:perf && npm run seo:lighthouse && npm run seo:pagespeed && npm run seo:crux",
    "seo:sitemap-index": "node scripts/finalize-sitemap-index.mjs",
    "seo:startup": "npx wrangler check startup --outfile /tmp/lbsailab-worker-startup.cpuprofile",
    "deploy": "npm run seo:ci && npx wrangler deploy --keep-vars && npm run seo:live && npm run seo:perf && npm run seo:indexnow",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "astro": "^6.3.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@resvg/resvg-js": "^2.6.2",
    "@rollup/wasm-node": "^4.60.4",
    "js-yaml": "^4.2.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "rollup": "npm:@rollup/wasm-node@^4.60.4",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "description": "A content-driven Astro website for London Business School participants building AI products for LBS workflows.",
  "repository": {
    "type": "git",
    "url": "https://github.com/makriman/LBSAILAB.git"
  },
  "homepage": "https://lbsailab.com",
  "bugs": {
    "url": "https://github.com/makriman/LBSAILAB/issues"
  }
}
