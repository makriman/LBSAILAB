---
import Eyebrow from "./Eyebrow.astro";

interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  align?: "left" | "center";
  light?: boolean;
}

const { eyebrow, title, body, align = "left", light = false } = Astro.props;
---

<div class:list={["section-header", `align-${align}`, { light }]}>
  {eyebrow && <Eyebrow text={eyebrow} light={light} />}
  <h2>{title}</h2>
  {body && <p>{body}</p>}
</div>

<style>
  .section-header {
    display: grid;
    gap: 18px;
    max-width: 760px;
  }

  .section-header h2 {
    color: var(--color-lbs-blue);
    margin: 0;
  }

  .section-header p {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
  }

  .section-header.light h2,
  .section-header.light p {
    color: var(--color-white);
  }

  .section-header.light p {
    opacity: 0.78;
  }

  .align-center {
    margin-inline: auto;
    text-align: center;
  }

  .align-center :global(.eyebrow) {
    justify-self: center;
  }
</style>
