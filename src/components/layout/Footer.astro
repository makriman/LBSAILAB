---
import { DSAI_URL, LBS_URL } from "@utils/site";
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-main">
      <div class="footer-brand">
        <a class="brand" href="/" aria-label="LBS AI Lab home">
          <strong>LBS AI Lab</strong>
          <span>Build. Test. Iterate.</span>
        </a>
        <p>
          A practical AI lab for LBS students learning to build products, test
          with real users, and improve from feedback.
        </p>
      </div>

      <div class="footer-cta">
        <span>Next cohort</span>
        <strong>September 2026</strong>
        <a href="/apply/">Register interest</a>
      </div>
    </div>

    <div class="footer-nav-grid">
      <nav aria-label="Explore" class="footer-links">
        <h2>Explore</h2>
        <a href="/about/">About</a>
        <a href="/cohorts/">Cohorts</a>
        <a href="/teams/">Teams</a>
        <a href="/mentors/">Mentors</a>
      </nav>

      <nav aria-label="Build loop" class="footer-links">
        <h2>Build loop</h2>
        <a href="/apply/#register-interest">Register interest</a>
        <a href="/apply/#submissions">Find co-builders</a>
        <a href="/contact/">Contact the Lab</a>
      </nav>

      <nav aria-label="Institution links" class="footer-links">
        <h2>LBS</h2>
        <a href={DSAI_URL} target="_blank" rel="noreferrer">
          Data Science & AI Initiative
        </a>
        <a href={LBS_URL} target="_blank" rel="noreferrer">
          London Business School
        </a>
      </nav>
    </div>

    <div class="footer-bottom">
      <span>London Business School</span>
      <span>Student-built AI products for real LBS use cases.</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-lbs-blue);
    color: var(--color-white);
  }

  .footer-inner {
    display: grid;
    gap: clamp(32px, 5vw, 58px);
    margin-inline: auto;
    max-width: var(--container);
    padding: clamp(42px, 7vw, 72px) var(--gutter) 28px;
  }

  .footer-main {
    align-items: end;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 0.35fr);
    padding-bottom: clamp(28px, 4vw, 42px);
  }

  .brand {
    color: var(--color-white);
    display: inline-grid;
    gap: 5px;
    text-decoration: none;
  }

  .brand strong {
    font-size: clamp(1.55rem, 3vw, 2.4rem);
    line-height: 1;
  }

  .brand span {
    color: rgba(255, 255, 255, 0.72);
    font-size: var(--step--1);
    font-weight: 820;
  }

  .footer-brand p {
    color: rgba(255, 255, 255, 0.75);
    font-size: var(--step-1);
    line-height: 1.38;
    margin: 22px 0 0;
    max-width: 680px;
  }

  .footer-cta {
    border: 1px solid rgba(255, 255, 255, 0.22);
    display: grid;
    gap: 12px;
    padding: 20px;
  }

  .footer-cta span,
  .footer-links h2,
  .footer-bottom {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .footer-cta strong {
    color: var(--color-white);
    font-family: var(--font-serif);
    font-size: var(--step-1);
    line-height: 1;
  }

  .footer-cta a {
    align-items: center;
    background: var(--color-white);
    border-radius: var(--radius-button);
    color: var(--color-lbs-blue);
    display: inline-flex;
    font-weight: 900;
    justify-content: center;
    min-height: 42px;
    padding: 10px 16px;
    text-decoration: none;
  }

  .footer-nav-grid {
    display: grid;
    gap: 28px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .footer-links {
    align-content: start;
    display: grid;
    gap: 12px;
  }

  .footer-links h2 {
    margin: 0 0 4px;
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.84);
    font-weight: 760;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--color-white);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: space-between;
    padding-top: 22px;
    text-transform: none;
  }

  @media (max-width: 820px) {
    .footer-main,
    .footer-nav-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
