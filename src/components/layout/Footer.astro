---
import { DSAI_URL, LBS_URL } from "@utils/site";

const labLinks = [
  { href: "/about/", label: "About" },
  { href: "/cohorts/", label: "Cohorts" },
  { href: "/teams/", label: "Teams" },
  { href: "/mentors/", label: "Mentors" },
  { href: "/contact/", label: "Contact" },
];

const institutionLinks = [
  { href: DSAI_URL, label: "DSAI Initiative" },
  { href: LBS_URL, label: "London Business School" },
];

const socialLinks = [
  {
    href: "http://www.linkedin.com/company/london-business-school",
    label: "LinkedIn",
  },
  {
    href: "http://www.youtube.com/user/londonbusinessschool",
    label: "YouTube",
  },
  {
    href: "https://www.instagram.com/londonbschool/?hl=en",
    label: "Instagram",
  },
  { href: "http://www.facebook.com/londonbusinessschool", label: "Facebook" },
  { href: "http://www.twitter.com/lbs", label: "X" },
  {
    href: "https://mp.weixin.qq.com/s/tR-No6jRcyxTTAkghnfmwA",
    label: "WeChat",
  },
  {
    href: "https://www.rednote.com/user/profile/66686da60000000007007d32?xsec_token=AB0FHoU_3finTNE7HFaFnCS4tYmOmaf8SX2HS1Cbg85qQ",
    label: "Rednote",
  },
  {
    href: "https://www.weibo.com/londonbusinessschool?is_all=1",
    label: "Weibo",
  },
  { href: "https://admissionsblog.london.edu/", label: "Admissions Blog" },
];

const legalLinks = [
  {
    href: `${LBS_URL}about/london-business-school/policies-and-legislation/website-privacy-policy`,
    label: "Privacy",
  },
  {
    href: `${LBS_URL}about/london-business-school/policies-and-legislation`,
    label: "Policies",
  },
  { href: "/sitemap-index.xml", label: "Sitemap" },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-main">
      <div class="footer-brand">
        <a class="brand" href="/" aria-label="LBS AI Lab home">
          <strong>LBS AI Lab</strong>
          <span>Build. Test. Iterate.</span>
        </a>
        <p>
          A practical AI lab for LBS students building products, testing with
          real users, and improving from feedback.
        </p>
      </div>

      <nav aria-label="AI Lab links" class="footer-links">
        {labLinks.map((link) => <a href={link.href}>{link.label}</a>)}
      </nav>

      <div class="footer-actions">
        <a href="/apply/">Register interest</a>
        <a href="/apply/#submissions">Find co-builders</a>
      </div>
    </div>

    <div class="footer-meta">
      <nav aria-label="Institution links" class="institution-links">
        {
          institutionLinks.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">
              {link.label}
            </a>
          ))
        }
      </nav>

      <nav aria-label="LBS in social media" class="social-links">
        <span>LBS social</span>
        {
          socialLinks.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="footer-bottom">
      <span>© London Business School {year}</span>
      <nav aria-label="Legal links">
        {
          legalLinks.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith("http") ? "_blank" : undefined}
              rel={link.href.startsWith("http") ? "noreferrer" : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-lbs-blue);
    color: var(--color-white);
  }

  .footer-inner {
    display: grid;
    gap: 12px;
    margin-inline: auto;
    max-width: var(--container);
    padding: clamp(24px, 3vw, 34px) var(--gutter) 18px;
  }

  .footer-main {
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(260px, 0.95fr) minmax(260px, 0.85fr) auto;
    padding-bottom: 14px;
  }

  .brand {
    color: var(--color-white);
    display: inline-grid;
    gap: 5px;
    text-decoration: none;
  }

  .brand strong {
    font-size: clamp(1.35rem, 2vw, 1.75rem);
    line-height: 1;
  }

  .brand span,
  .footer-brand p,
  .footer-meta span,
  .footer-bottom {
    color: rgba(255, 255, 255, 0.66);
  }

  .brand span,
  .footer-meta span,
  .footer-bottom {
    font-size: 0.78rem;
    font-weight: 820;
  }

  .footer-brand p {
    font-size: var(--step--1);
    line-height: 1.32;
    margin: 8px 0 0;
    max-width: 480px;
  }

  .footer-links,
  .institution-links,
  .social-links,
  .footer-bottom nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
  }

  .footer-links a,
  .institution-links a,
  .social-links a,
  .footer-bottom a {
    color: rgba(255, 255, 255, 0.84);
    font-size: 0.86rem;
    font-weight: 760;
    text-decoration: none;
  }

  .footer-links a:hover,
  .institution-links a:hover,
  .social-links a:hover,
  .footer-bottom a:hover {
    color: var(--color-white);
  }

  .footer-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
  }

  .footer-actions a {
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.26);
    border-radius: var(--radius-button);
    color: var(--color-white);
    display: inline-flex;
    font-size: 0.8rem;
    font-weight: 880;
    min-height: 34px;
    padding: 7px 11px;
    text-decoration: none;
  }

  .footer-actions a:first-child {
    background: var(--color-white);
    color: var(--color-lbs-blue);
  }

  .footer-meta {
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(0, 0.45fr) minmax(0, 1fr);
    padding-bottom: 12px;
  }

  .social-links {
    align-items: center;
  }

  .social-links span {
    color: rgba(255, 255, 255, 0.56);
    text-transform: uppercase;
  }

  .footer-bottom {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: space-between;
  }

  .footer-bottom a {
    font-size: 0.78rem;
  }

  @media (max-width: 940px) {
    .footer-main,
    .footer-meta {
      grid-template-columns: 1fr;
    }

    .footer-actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 560px) {
    .footer-inner {
      padding-block: 22px 16px;
    }

    .footer-main {
      gap: 10px;
      padding-bottom: 10px;
    }

    .footer-brand p {
      display: none;
    }

    .footer-actions {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: 100%;
    }

    .footer-actions a {
      justify-content: center;
      min-height: 36px;
      padding-inline: 9px;
      text-align: center;
      white-space: nowrap;
    }

    .social-links {
      flex-wrap: nowrap;
      margin-inline: calc(var(--gutter) * -1);
      overflow-x: auto;
      padding-inline: var(--gutter);
      scrollbar-width: none;
      white-space: nowrap;
    }

    .social-links::-webkit-scrollbar {
      display: none;
    }

    .footer-meta {
      gap: 8px;
      padding-bottom: 10px;
    }

    .footer-bottom {
      gap: 8px;
    }
  }
</style>
