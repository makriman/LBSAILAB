---
import Button from "@components/atoms/Button.astro";
import { DSAI_URL } from "@utils/site";

const navItems = [
  { href: "/about/", label: "About" },
  { href: "/cohorts/", label: "Cohorts" },
  { href: "/teams/", label: "Teams" },
  { href: "/mentors/", label: "Mentors" },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header" data-site-header>
  <div class="header-inner">
    <a class="brand" href="/" aria-label="LBS AI Lab home">
      <span class="brand-logo" aria-hidden="true">
        <img src="/lbs-logo.svg" alt="" width="44" height="44" />
      </span>
      <span class="brand-text">
        <strong>AI Lab</strong>
        <span>Build. Test. Iterate.</span>
      </span>
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-navigation"
      data-menu-toggle
    >
      <span class="visually-hidden">Toggle navigation</span>
      <span class="menu-line menu-line-top" aria-hidden="true"></span>
      <span class="menu-line menu-line-bottom" aria-hidden="true"></span>
    </button>

    <nav
      class="primary-nav"
      id="primary-navigation"
      aria-label="Primary navigation"
      data-primary-nav
    >
      <ul>
        {
          navItems.map((item) => {
            const isCurrent =
              item.href === "/"
                ? currentPath === "/"
                : currentPath.startsWith(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  aria-current={isCurrent ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
      <a class="dsai-link" href={DSAI_URL} target="_blank" rel="noreferrer">
        DSAI Initiative
      </a>
      <Button href="/apply/" variant="primary" size="sm"
        >Register for September 2026</Button
      >
    </nav>
  </div>
</header>

<script is:inline>
  const header = document.querySelector("[data-site-header]");
  const toggle = document.querySelector("[data-menu-toggle]");
  const nav = document.querySelector("[data-primary-nav]");

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!isOpen));
    nav?.toggleAttribute("data-open", !isOpen);
    document.body.classList.toggle("menu-open", !isOpen);
    header?.toggleAttribute("data-open", !isOpen);
  });
</script>

<style>
  .site-header {
    background: rgba(255, 255, 255, 0.96);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    align-items: center;
    display: flex;
    gap: 28px;
    justify-content: space-between;
    margin-inline: auto;
    max-width: var(--container);
    min-height: 78px;
    padding-inline: var(--gutter);
  }

  .brand {
    align-items: center;
    color: var(--color-lbs-blue);
    display: inline-flex;
    gap: 11px;
    text-decoration: none;
  }

  .brand-logo {
    align-items: center;
    background: var(--color-lbs-blue);
    display: inline-flex;
    height: 44px;
    justify-content: center;
    width: 44px;
  }

  .brand-logo img {
    display: block;
    height: 44px;
    width: 44px;
  }

  .brand-text {
    display: grid;
    gap: 2px;
  }

  .brand-text strong {
    font-size: 1.08rem;
    line-height: 1;
  }

  .brand-text span {
    color: var(--color-muted);
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .primary-nav {
    align-items: center;
    display: flex;
    gap: 22px;
  }

  .primary-nav ul {
    align-items: center;
    display: flex;
    gap: 20px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .primary-nav a {
    color: var(--color-ink);
    font-size: var(--step--1);
    font-weight: 760;
    text-decoration: none;
  }

  .primary-nav a[aria-current="page"] {
    color: var(--color-lbs-red);
  }

  .dsai-link {
    border-left: 1px solid var(--color-border);
    color: var(--color-lbs-blue) !important;
    padding-left: 22px;
  }

  .menu-toggle {
    align-items: center;
    background: var(--color-lbs-blue);
    border: 0;
    border-radius: 0;
    color: var(--color-white);
    display: none;
    height: 44px;
    justify-content: center;
    padding: 0;
    width: 44px;
  }

  .menu-line {
    background: currentColor;
    height: 2px;
    position: absolute;
    transition:
      transform 180ms ease,
      opacity 180ms ease;
    width: 20px;
  }

  .menu-line-top {
    transform: translateY(-4px);
  }

  .menu-line-bottom {
    transform: translateY(4px);
  }

  .menu-toggle[aria-expanded="true"] .menu-line-top {
    transform: rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] .menu-line-bottom {
    transform: rotate(-45deg);
  }

  @media (max-width: 980px) {
    .menu-toggle {
      display: inline-flex;
      position: relative;
    }

    .primary-nav {
      align-items: stretch;
      background: var(--color-white);
      border-top: 1px solid var(--color-border);
      display: none;
      flex-direction: column;
      gap: 18px;
      inset: 78px 0 0 0;
      overflow-y: auto;
      padding: 24px var(--gutter) 32px;
      position: fixed;
      box-shadow: var(--shadow-card);
    }

    .primary-nav[data-open] {
      display: flex;
    }

    .primary-nav ul {
      align-items: stretch;
      flex-direction: column;
      gap: 0;
    }

    .primary-nav li {
      border-bottom: 1px solid var(--color-border);
    }

    .primary-nav a {
      display: block;
      font-size: var(--step-1);
      padding-block: 16px;
    }

    .dsai-link {
      border-left: 0;
      padding-left: 0;
    }
  }

  @media (max-width: 520px) {
    .brand-text span {
      display: none;
    }
  }
</style>
