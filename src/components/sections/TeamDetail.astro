---
import type { TeamEntry } from "@utils/collections";
import Button from "@components/atoms/Button.astro";
import GoogleDeepMindLogo from "@components/brand/GoogleDeepMindLogo.astro";

interface Props {
  team: TeamEntry;
  relatedTeams: TeamEntry[];
}

const { team, relatedTeams } = Astro.props;
---

<article class="team-detail">
  <section class="team-hero">
    <div class="container hero-inner">
      <div>
        <p class="eyebrow">Cohort 01 project</p>
        <h1>{team.data.displayName}</h1>
        <p class="lede">{team.data.tagline}</p>
        <div class="team-partner">
          <GoogleDeepMindLogo
            tone="light"
            compact
            label="Cohort 01 in partnership with"
          />
        </div>
        <div class="hero-actions">
          {
            team.data.productUrl && (
              <Button href={team.data.productUrl} variant="red" size="lg">
                View product
              </Button>
            )
          }
        </div>
      </div>
      <aside class="meta-panel" aria-label="Project metadata">
        <dl>
          <div>
            <dt>Cohort</dt>
            <dd>{team.data.cohortLabel}</dd>
          </div>
          <div>
            <dt>Status</dt>
            <dd>{team.data.status}</dd>
          </div>
          <div>
            <dt>Partner cohort</dt>
            <dd>Google DeepMind</dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container profile-grid">
      <div class="profile-main">
        <section>
          <p class="eyebrow">The problem</p>
          <h2>A real LBS workflow, treated as a product opportunity.</h2>
          <p>
            The team is focused on a practical student, operator, or
            professional workflow where AI can reduce friction, reach real
            users, and help people make better decisions faster.
          </p>
        </section>

        <section>
          <p class="eyebrow">What the team is building</p>
          <h2>{team.data.displayName}</h2>
          <p>{team.data.summary}</p>
        </section>

        <section>
          <p class="eyebrow">Cohort context</p>
          <h2>Built inside the founding cohort.</h2>
          <p>
            This project is part of Cohort 01, delivered in partnership with
            Google DeepMind and running from 10 April to 12 June 2026.
          </p>
        </section>
      </div>

      <aside class="profile-side">
        <section class="member-card">
          <h2>Team</h2>
          <ul>
            {
              team.data.members.map((member) => (
                <li>
                  <strong>{member.name}</strong>
                  <span>{member.role}</span>
                  <a href={`mailto:${member.email}`}>{member.email}</a>
                </li>
              ))
            }
          </ul>
        </section>
      </aside>
    </div>
  </section>

  {
    relatedTeams.length > 0 && (
      <section class="section section-cloud related">
        <div class="container">
          <p class="eyebrow">Related teams</p>
          <h2>More Cohort 01 builds</h2>
          <div class="related-list">
            {relatedTeams.map((related) => (
              <a href={`/teams/${related.data.slug}/`}>
                <strong>{related.data.displayName}</strong>
                <span>{related.data.tagline}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
</article>

<style>
  .team-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(70px, 10vw, 128px);
  }

  .hero-inner {
    align-items: end;
    display: grid;
    gap: clamp(36px, 6vw, 80px);
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.55fr);
  }

  :global(.team-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.8);
  }

  h1 {
    color: var(--color-white);
    margin: 20px 0;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    max-width: 760px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .team-partner {
    margin-top: 22px;
  }

  .meta-panel {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 26px;
  }

  dl {
    display: grid;
    gap: 20px;
    margin: 0;
  }

  dt {
    color: rgba(255, 255, 255, 0.58);
    font-size: var(--step--1);
    font-weight: 820;
  }

  dd {
    color: var(--color-white);
    font-weight: 760;
    margin: 5px 0 0;
  }

  .profile-grid {
    align-items: start;
    display: grid;
    gap: clamp(36px, 6vw, 86px);
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
  }

  .profile-main {
    display: grid;
    gap: clamp(42px, 6vw, 72px);
  }

  .profile-main section {
    border-left: 3px solid var(--color-lbs-red);
    padding-left: clamp(22px, 3vw, 34px);
  }

  .profile-main h2 {
    color: var(--color-lbs-blue);
    font-size: var(--step-2);
    margin: 14px 0;
  }

  .profile-main p:not(.eyebrow) {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
  }

  .profile-side {
    display: grid;
    gap: 18px;
    position: sticky;
    top: 104px;
  }

  .member-card {
    background: var(--color-warm-white);
    border: 1px solid var(--color-border);
    padding: 24px;
  }

  .member-card h2 {
    color: var(--color-lbs-blue);
    font-family: var(--font-sans);
    font-size: var(--step-1);
    line-height: 1.15;
    margin: 0 0 18px;
  }

  .member-card ul {
    display: grid;
    gap: 16px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .member-card li {
    border-top: 1px solid var(--color-border);
    display: grid;
    gap: 3px;
    padding-top: 14px;
  }

  .member-card strong {
    color: var(--color-lbs-blue);
  }

  .member-card span,
  .member-card em,
  .member-card p {
    color: var(--color-muted);
    font-size: var(--step--1);
    font-style: normal;
    font-weight: 700;
  }

  .member-card a {
    font-size: var(--step--1);
    font-weight: 820;
  }

  .related h2 {
    color: var(--color-lbs-blue);
    margin: 16px 0 24px;
  }

  .related-list {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .related-list a {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: grid;
    gap: 8px;
    padding: 20px;
    text-decoration: none;
  }

  .related-list strong {
    color: var(--color-lbs-blue);
    font-size: var(--step-1);
  }

  .related-list span {
    color: var(--color-muted);
    font-size: var(--step--1);
    font-weight: 760;
  }

  @media (max-width: 900px) {
    .hero-inner,
    .profile-grid {
      grid-template-columns: 1fr;
    }

    .profile-side {
      position: static;
    }

    .related-list {
      grid-template-columns: 1fr;
    }
  }
</style>
