---
import type { TeamEntry } from "@utils/collections";
import Button from "@components/atoms/Button.astro";

interface Props {
  team: TeamEntry;
}

const { team } = Astro.props;

const category = team.data.category.toLowerCase();
const focusArea = category.includes("career")
  ? "Recruiting"
  : category.includes("event") || category.includes("club")
    ? "Events"
    : category.includes("academic") || category.includes("elective")
      ? "Electives"
      : category.includes("funding") || category.includes("admissions")
        ? "Funding"
        : category.includes("professional")
          ? "Professional work"
          : "Campus";
---

<article class="team-detail">
  <section class="team-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Spring 2026 Batch</p>
        <h1>{team.data.displayName}</h1>
        <p class="lede">{team.data.tagline}</p>
      </div>
      <aside class="meta-panel" aria-label="Team metadata">
        <dl>
          <div>
            <dt>Batch</dt>
            <dd>Spring 2026</dd>
          </div>
          <div>
            <dt>Focus area</dt>
            <dd>{focusArea}</dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container detail-grid">
      <div class="main-content">
        <section>
          <p class="eyebrow">Product overview</p>
          <h2>Product overview</h2>
          <p>{team.data.summary}</p>
        </section>

        <section>
          <p class="eyebrow">What they are building</p>
          <h2>What they are building</h2>
          <div class="build-grid">
            <article>
              <h3>User need</h3>
              <p>
                The team is addressing an LBS workflow in {team.data.category}
              </p>
            </article>
            <article>
              <h3>Product approach</h3>
              <p>{team.data.tagline}</p>
            </article>
            <article>
              <h3>Next step</h3>
              <p>
                Test quality, gather feedback, and improve the prototype through
                iteration
              </p>
            </article>
          </div>
        </section>

        {
          team.data.productUrl && (
            <section>
              <p class="eyebrow">Try the product</p>
              <h2>Try the product</h2>
              <Button href={team.data.productUrl} variant="secondary">
                Open prototype
              </Button>
            </section>
          )
        }

        <a class="back-link" href="/batches/spring-2026/"
          >Back to Spring 2026 Batch</a
        >
      </div>

      <aside class="team-members">
        <h2>Team members</h2>
        <ul>
          {
            team.data.members.map((member) => (
              <li>
                <strong>{member.name}</strong>
                <span>{member.role}</span>
                {member.showEmailPublicly && (
                  <a href={`mailto:${member.email}`}>Email</a>
                )}
              </li>
            ))
          }
        </ul>
      </aside>
    </div>
  </section>
</article>

<style>
  .team-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(52px, 7vw, 92px);
  }

  .hero-grid {
    align-items: end;
    display: grid;
    gap: clamp(30px, 6vw, 72px);
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.36fr);
  }

  :global(.team-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  h1 {
    color: var(--color-white);
    margin: 20px 0;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    max-width: 760px;
  }

  .meta-panel {
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 22px;
  }

  dl {
    display: grid;
    gap: 18px;
    margin: 0;
  }

  dt {
    color: rgba(255, 255, 255, 0.62);
    font-size: var(--step--1);
    font-weight: 820;
  }

  dd {
    color: var(--color-white);
    font-weight: 780;
    margin: 5px 0 0;
  }

  .detail-grid {
    align-items: start;
    display: grid;
    gap: clamp(36px, 7vw, 88px);
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.34fr);
  }

  .main-content {
    display: grid;
    gap: clamp(42px, 7vw, 70px);
  }

  .main-content h2,
  .team-members h2 {
    color: var(--color-lbs-blue);
    font-size: var(--step-2);
    margin: 12px 0 14px;
  }

  .main-content p:not(.eyebrow),
  .build-grid p {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
  }

  .build-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 22px;
  }

  .build-grid article {
    border-top: 2px solid var(--color-lbs-red);
    padding-top: 18px;
  }

  .build-grid h3 {
    color: var(--color-lbs-blue);
    font-family: var(--font-sans);
    font-size: var(--step-0);
    margin: 0 0 10px;
  }

  .build-grid p {
    font-size: 0.98rem;
    line-height: 1.45;
    margin: 0;
  }

  .team-members {
    background: var(--color-warm-white);
    border: 1px solid var(--color-border);
    padding: 22px;
    position: sticky;
    top: 104px;
  }

  .team-members h2 {
    font-size: var(--step-1);
    margin-top: 0;
  }

  .team-members ul {
    display: grid;
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .team-members li {
    border-top: 1px solid var(--color-border);
    display: grid;
    gap: 4px;
    padding-top: 12px;
  }

  .team-members strong {
    color: var(--color-lbs-blue);
  }

  .team-members span,
  .team-members a {
    color: var(--color-muted);
    font-size: var(--step--1);
    font-weight: 760;
  }

  .team-members a {
    color: var(--color-lbs-blue);
    text-decoration: none;
  }

  .back-link {
    color: var(--color-lbs-blue);
    font-weight: 860;
    text-decoration: none;
  }

  .back-link::before {
    color: var(--color-lbs-red);
    content: "<- ";
  }

  @media (max-width: 900px) {
    .hero-grid,
    .detail-grid,
    .build-grid {
      grid-template-columns: 1fr;
    }

    .team-members {
      position: static;
    }
  }
</style>
