---
const areas = [
  {
    name: "Career search",
    teams: "RecruitSmart LBS, The Wayfinders",
    users: "students navigating recruiting",
  },
  {
    name: "Campus operations",
    teams: "EventOS, EMS++, Cafe Smart Campus",
    users: "clubs, events, and daily campus workflows",
  },
  {
    name: "Learning and planning",
    teams: "LBS Compass, Briefd",
    users: "students choosing courses and processing information",
  },
  {
    name: "Funding and work",
    teams: "FundED, Zentra",
    users: "founders, operators, and professional teams",
  },
];
---

<figure
  class="lab-signal"
  aria-label="Cohort 01 problem areas and user audiences"
>
  <div class="panel-heading">
    <span>Cohort 01</span>
    <strong>Problem areas</strong>
  </div>
  <ol class="area-list">
    {
      areas.map((area, index) => (
        <li>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <div>
            <strong>{area.name}</strong>
            <p>{area.teams}</p>
            <em>{area.users}</em>
          </div>
        </li>
      ))
    }
  </ol>
  <div class="panel-footer">
    <span>9 teams</span>
    <span>LBS-first use cases</span>
    <span>real user feedback</span>
  </div>
</figure>

<style>
  .lab-signal {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
    margin: 0;
    padding: clamp(18px, 3vw, 28px);
  }

  .panel-heading,
  .panel-footer {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: space-between;
  }

  .panel-heading span,
  .panel-footer span {
    color: var(--color-muted);
    font-size: var(--step--1);
    font-weight: 820;
  }

  .panel-heading strong {
    color: var(--color-lbs-blue);
    font-size: var(--step-1);
  }

  .area-list {
    display: grid;
    gap: 0;
    list-style: none;
    margin: 24px 0;
    padding: 0;
  }

  .area-list li {
    border-top: 1px solid var(--color-border);
    display: grid;
    gap: 16px;
    grid-template-columns: 42px minmax(0, 1fr);
    padding-block: 18px;
  }

  .area-list li:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .area-list li > span {
    color: var(--color-lbs-red);
    font-size: 0.82rem;
    font-weight: 900;
  }

  .area-list strong {
    color: var(--color-lbs-blue);
    display: block;
    font-size: clamp(1.08rem, 2vw, 1.34rem);
    line-height: 1.05;
  }

  .area-list p {
    color: var(--color-ink-soft);
    font-weight: 820;
    margin: 8px 0 4px;
  }

  .area-list em {
    color: var(--color-muted);
    font-size: var(--step--1);
    font-style: normal;
    font-weight: 720;
  }
</style>
