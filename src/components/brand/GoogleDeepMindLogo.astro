---
import { GOOGLE_DEEPMIND_URL } from "@utils/site";

interface Props {
  label?: string;
  tone?: "dark" | "light";
  compact?: boolean;
}

const {
  label = "In partnership with",
  tone = "dark",
  compact = false,
} = Astro.props;
const ariaLabel = label ? `${label} Google DeepMind` : "Google DeepMind";
---

<a
  class:list={["gdm-lockup", tone, { compact }]}
  href={GOOGLE_DEEPMIND_URL}
  target="_blank"
  rel="noreferrer"
  aria-label={ariaLabel}
>
  {label && <span class="label">{label}</span>}
  <span class="mark">
    <img src="/deepmind-new-logo.svg" alt="DeepMind" loading="eager" />
  </span>
</a>

<style>
  .gdm-lockup {
    align-items: center;
    display: inline-flex;
    flex-wrap: wrap;
    gap: 10px;
    text-decoration: none;
  }

  .label {
    color: var(--color-muted);
    font-size: var(--step--1);
    font-weight: 820;
  }

  .light .label {
    color: rgba(255, 255, 255, 0.78);
  }

  .mark {
    align-items: center;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: inline-flex;
    min-height: 44px;
    padding: 9px 14px;
  }

  .light .mark {
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.22);
  }

  .compact .mark {
    min-height: 38px;
    padding: 8px 12px;
  }

  img {
    height: auto;
    width: clamp(150px, 18vw, 205px);
  }

  .compact img {
    width: clamp(128px, 14vw, 170px);
  }
</style>
