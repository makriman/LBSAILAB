---
import { GOOGLE_DEEPMIND_URL } from "@utils/site";

interface Props {
  label?: string;
  tone?: "dark" | "light";
  compact?: boolean;
}

const {
  label = "In partnership with",
  tone = "dark",
  compact = false,
} = Astro.props;
const ariaLabel = label ? `${label} Google DeepMind` : "Google DeepMind";
---

<a
  class:list={["gdm-lockup", tone, { compact }]}
  href={GOOGLE_DEEPMIND_URL}
  target="_blank"
  rel="noreferrer"
  aria-label={ariaLabel}
>
  {label && <span class="label">{label}</span>}
  <span class="mark">
    <img src="/deepmind-new-logo.svg" alt="DeepMind" loading="eager" />
  </span>
</a>

<style>
  .gdm-lockup {
    align-items: start;
    display: inline-grid;
    gap: 8px;
    max-width: 100%;
    text-decoration: none;
  }

  .label {
    color: var(--color-muted);
    font-size: var(--step--1);
    font-weight: 820;
  }

  .light .label {
    color: rgba(255, 255, 255, 0.78);
  }

  .mark {
    display: inline-flex;
    max-width: 100%;
  }

  .light .mark {
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.28);
    padding: 8px 10px;
  }

  img {
    height: auto;
    width: clamp(150px, 17vw, 198px);
  }

  .compact img {
    width: clamp(130px, 13vw, 168px);
  }
</style>
