---
import { GOOGLE_DEEPMIND_URL } from "@utils/site";

interface Props {
  label?: string;
  tone?: "dark" | "light";
  compact?: boolean;
}

const {
  label = "In partnership with",
  tone = "dark",
  compact = false,
} = Astro.props;
const ariaLabel = label ? `${label} Google DeepMind` : "Google DeepMind";
const logoSrc =
  tone === "light"
    ? "/google-deepmind-logo-white.png"
    : "/google-deepmind-logo-blue.png";
---

<a
  class:list={["gdm-lockup", tone, { compact }]}
  href={GOOGLE_DEEPMIND_URL}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={ariaLabel}
>
  {label && <span class="label">{label}</span>}
  <span class="mark">
    <img
      src={logoSrc}
      alt="Google DeepMind"
      width="694"
      height="116"
      loading="eager"
    />
  </span>
</a>

<style>
  .gdm-lockup {
    align-items: start;
    display: inline-grid;
    gap: 8px;
    max-width: 100%;
    text-decoration: none;
  }

  .label {
    color: var(--color-muted);
    font-size: var(--step--1);
    font-weight: 820;
  }

  .light .label {
    color: rgba(255, 255, 255, 0.78);
  }

  .mark {
    display: inline-flex;
    max-width: 100%;
  }

  .light .mark {
    background: transparent;
    border: 0;
    padding: 0;
  }

  img {
    display: block;
    height: auto;
    width: clamp(210px, 22vw, 292px);
  }

  .compact img {
    width: clamp(190px, 18vw, 260px);
  }
</style>
