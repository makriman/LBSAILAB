---
import { GOOGLE_DEEPMIND_URL } from "@utils/site";

interface Props {
  label?: string;
  tone?: "dark" | "light";
  compact?: boolean;
}

const {
  label = "In partnership with",
  tone = "dark",
  compact = false,
} = Astro.props;
const ariaLabel = label ? `${label} Google DeepMind` : "Google DeepMind";
---

<a
  class:list={["gdm-lockup", tone, { compact }]}
  href={GOOGLE_DEEPMIND_URL}
  target="_blank"
  rel="noreferrer"
  aria-label={ariaLabel}
>
  {label && <span class="label">{label}</span>}
  <span class="mark" aria-hidden="true">
    <svg class="deepmind-icon" viewBox="0 0 192 192" focusable="false">
      <path
        fill="currentColor"
        d="M133.52 16.39C122.52 11.17 109.43 8 97 8 59.48 8 37.04 39.06 39.45 69.4c1.09 13.73 7.83 27.02 18.98 37.4 4.14 3.84 8.62 7.04 13.26 9.53a31.482 31.482 0 0 1-6.98-15.19C62.22 85.89 72.28 63.45 98 63.45c27.66 0 58.14 26.31 60.69 58.64 1.58 19.77-5.93 37.61-18.6 50.04C166.37 156.9 184 128.5 184 96c0-35.17-20.65-65.53-50.48-79.61z"
      ></path>
      <path
        fill="currentColor"
        d="M152.55 122.6c-1.09-13.73-7.83-27.02-18.98-37.4-4.14-3.84-8.62-7.04-13.26-9.53 3.58 4.25 6.04 9.47 6.98 15.19 2.49 15.25-7.57 37.69-33.29 37.69-27.66 0-58.14-26.31-60.69-58.64-1.58-19.77 5.93-37.61 18.6-50.04C25.63 35.1 8 63.5 8 96c0 35.17 20.65 65.53 50.48 79.61 11 5.22 24.08 8.39 36.52 8.39 37.52 0 59.96-31.06 57.55-61.4z"
      ></path>
    </svg>
    <span class="deepmind-word">Google DeepMind</span>
  </span>
</a>

<style>
  .gdm-lockup {
    align-items: center;
    color: var(--color-gdm-blue, #1a73e8);
    display: inline-flex;
    flex-wrap: wrap;
    gap: 10px;
    text-decoration: none;
  }

  .gdm-lockup.light {
    color: var(--color-gdm-blue, #1a73e8);
  }

  .label {
    color: var(--color-muted);
    font-size: var(--step--1);
    font-weight: 820;
  }

  .light .label {
    color: rgba(255, 255, 255, 0.78);
  }

  .mark {
    align-items: center;
    background: var(--color-gdm-blue);
    color: var(--color-white);
    display: inline-flex;
    gap: 11px;
    min-height: 44px;
    padding: 10px 16px;
  }

  .light .mark {
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.22);
  }

  .compact .mark {
    min-height: 38px;
    padding: 8px 13px;
  }

  .deepmind-icon {
    color: var(--color-white);
    height: 30px;
    width: 30px;
  }

  .deepmind-word {
    font-family: var(--font-sans);
    font-size: 1.18rem;
    font-weight: 520;
    line-height: 1;
    white-space: nowrap;
  }

  .compact .deepmind-icon {
    height: 25px;
    width: 25px;
  }

  .compact .deepmind-word {
    font-size: 1rem;
  }
</style>
