---
const director = {
  name: "Kostis Christodoulou",
  title: "Head of LBS AI Lab",
  role: "Clinical Professor of Management Science and Operations; Academic Director (MBA, MAM, EMBAG)",
  focus:
    "Academic leadership for the Lab, connecting student builders with rigorous AI, analytics, decision-making, and real-world product learning.",
  email: "kchristodoulou@london.edu",
  profileUrl:
    "https://www.london.edu/faculty-and-research/faculty-profiles/k/kostis-christodoulou",
  image: "/mentors/kostis-christodoulou.jpg",
};
---

<article class="director-card">
  <a
    class="director-photo"
    href={director.profileUrl}
    aria-label={`Open ${director.name} profile`}
    target="_blank"
    rel="noreferrer"
  >
    <img
      src={director.image}
      alt={director.name}
      loading="lazy"
      decoding="async"
    />
  </a>
  <div class="director-body">
    <p class="director-kicker">{director.title}</p>
    <h3>{director.name}</h3>
    <p class="director-role">{director.role}</p>
    <p>{director.focus}</p>
    <div class="director-links">
      <a class="connect-link" href={`mailto:${director.email}`}>Connect</a>
      <a
        class="profile-link"
        href={director.profileUrl}
        target="_blank"
        rel="noreferrer"
      >
        LBS profile
      </a>
    </div>
  </div>
</article>

<style>
  .director-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: minmax(220px, 0.32fr) minmax(0, 1fr);
    margin-top: 18px;
    min-height: 260px;
  }

  .director-photo {
    background: var(--color-cloud);
    border-right: 1px solid var(--color-border);
    display: block;
    overflow: hidden;
    text-decoration: none;
  }

  img {
    height: 100%;
    min-height: 260px;
    object-fit: cover;
    object-position: center;
    width: 100%;
  }

  .director-body {
    align-content: center;
    display: grid;
    gap: 12px;
    padding: clamp(24px, 4vw, 42px);
  }

  .director-kicker {
    color: var(--color-lbs-red);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    margin: 0;
    text-transform: uppercase;
  }

  h3 {
    color: var(--color-lbs-blue);
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 0.95;
    margin: 0;
  }

  .director-role {
    color: var(--color-lbs-blue);
    font-weight: 850;
    margin: 0;
  }

  .director-body p:not(.director-kicker):not(.director-role) {
    color: var(--color-ink-soft);
    font-size: var(--step-0);
    line-height: 1.45;
    margin: 0;
    max-width: 820px;
  }

  .director-links {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 8px;
  }

  .connect-link,
  .profile-link {
    align-items: center;
    display: inline-flex;
    font-size: var(--step--1);
    font-weight: 850;
    justify-content: center;
    min-height: 42px;
    padding: 10px 16px;
    text-decoration: none;
  }

  .connect-link {
    background: var(--color-lbs-blue);
    border-radius: var(--radius-button);
    color: var(--color-white);
  }

  .connect-link:hover {
    background: var(--color-lbs-red);
  }

  .profile-link {
    color: var(--color-lbs-blue);
    text-decoration: underline;
    text-decoration-color: rgba(205, 13, 47, 0.36);
  }

  @media (max-width: 760px) {
    .director-card {
      grid-template-columns: 1fr;
    }

    .director-photo {
      border-bottom: 1px solid var(--color-border);
      border-right: 0;
    }

    img {
      aspect-ratio: 4 / 3;
      min-height: 0;
    }
  }
</style>
