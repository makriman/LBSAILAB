---
const director = {
  name: "Kostis Christodoulou",
  title: "Academic lead",
  role: "Clinical Professor of Management Science and Operations; Academic Director (MBA, MAM, EMBAG)",
  focus:
    "Kostis supports the academic direction of the Lab, connecting participant teams with rigorous AI, analytics, decision-making, and product learning",
  email: "kchristodoulou@london.edu",
  profileUrl:
    "https://www.london.edu/faculty-and-research/faculty-profiles/k/kostis-christodoulou",
  image: "/mentors/kostis-christodoulou.jpg",
};
---

<article class="director-card">
  <a
    class="director-photo"
    href={director.profileUrl}
    aria-label={`Open ${director.name} profile`}
    target="_blank"
    rel="noreferrer"
  >
    <img
      src={director.image}
      alt={director.name}
      width="512"
      height="386"
      loading="lazy"
      decoding="async"
    />
  </a>
  <div class="director-body">
    <p class="director-kicker">{director.title}</p>
    <h3>{director.name}</h3>
    <p class="director-role">{director.role}</p>
    <p>{director.focus}</p>
    <div class="director-links">
      <a href={director.profileUrl} target="_blank" rel="noreferrer">
        LBS profile
      </a>
    </div>
  </div>
</article>

<style>
  .director-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: minmax(180px, 0.24fr) minmax(0, 1fr);
  }

  .director-photo {
    background: var(--color-cloud);
    border-right: 1px solid var(--color-border);
    display: block;
    min-height: 220px;
    overflow: hidden;
  }

  img {
    height: 100%;
    min-height: 220px;
    object-fit: cover;
    width: 100%;
  }

  .director-body {
    align-content: center;
    display: grid;
    gap: 10px;
    padding: clamp(22px, 4vw, 38px);
  }

  .director-kicker {
    color: var(--color-lbs-red);
    font-size: 0.78rem;
    font-weight: 900;
    margin: 0;
  }

  h3 {
    color: var(--color-lbs-blue);
    font-family: var(--font-sans);
    font-size: var(--step-2);
    line-height: 1.05;
    margin: 0;
  }

  .director-role {
    color: var(--color-lbs-blue);
    font-weight: 820;
    margin: 0;
  }

  .director-body p:not(.director-kicker):not(.director-role) {
    color: var(--color-ink-soft);
    line-height: 1.45;
    margin: 0;
    max-width: 760px;
  }

  .director-links {
    margin-top: 8px;
  }

  a {
    color: var(--color-lbs-blue);
    font-size: var(--step--1);
    font-weight: 850;
    text-decoration: none;
  }

  a::after {
    color: var(--color-lbs-red);
    content: " ->";
  }

  @media (max-width: 720px) {
    .director-card {
      grid-template-columns: 1fr;
    }

    .director-photo {
      border-bottom: 1px solid var(--color-border);
      border-right: 0;
      min-height: 0;
    }

    img {
      aspect-ratio: 4 / 3;
      min-height: 0;
    }
  }
</style>
