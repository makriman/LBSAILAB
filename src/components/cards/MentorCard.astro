---
import type { MentorEntry } from "@utils/collections";
import { initials } from "@utils/collections";

interface Props {
  mentor: MentorEntry;
}

const { mentor } = Astro.props;
---

<article class="mentor-card">
  <div class="avatar-wrap">
    {
      mentor.data.image ? (
        <img
          src={mentor.data.image}
          alt={mentor.data.name}
          width="72"
          height="72"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <span class="avatar" aria-hidden="true">
          {initials(mentor.data.name)}
        </span>
      )
    }
  </div>
  <div>
    <p class="mentor-type">{mentor.data.mentorType}</p>
    <h3>{mentor.data.name}</h3>
    {mentor.data.focus && <p class="mentor-focus">{mentor.data.focus}</p>}
    {
      mentor.data.linkedinUrl && (
        <a
          href={mentor.data.linkedinUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          Profile
        </a>
      )
    }
  </div>
</article>

<style>
  .mentor-card {
    align-items: start;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: grid;
    gap: 16px;
    grid-template-columns: 72px minmax(0, 1fr);
    padding: 18px;
  }

  .avatar-wrap,
  img,
  .avatar {
    aspect-ratio: 1 / 1;
    width: 72px;
  }

  .avatar-wrap {
    background: var(--color-cloud);
    overflow: hidden;
  }

  img {
    height: 72px;
    object-fit: cover;
  }

  .avatar {
    align-items: center;
    background: var(--color-lbs-blue);
    color: var(--color-white);
    display: flex;
    font-weight: 900;
    justify-content: center;
  }

  .mentor-type {
    color: var(--color-lbs-red);
    font-size: 0.76rem;
    font-weight: 900;
    margin: 0 0 8px;
  }

  h3 {
    color: var(--color-lbs-blue);
    font-family: var(--font-sans);
    font-size: var(--step-0);
    margin: 0;
  }

  .mentor-focus {
    color: var(--color-ink-soft);
    font-size: 0.92rem;
    line-height: 1.42;
    margin: 8px 0 10px;
  }

  a {
    color: var(--color-lbs-blue);
    font-size: var(--step--1);
    font-weight: 850;
    text-decoration: none;
  }

  a::after {
    color: var(--color-lbs-red);
    content: " ->";
  }

  @media (max-width: 420px) {
    .mentor-card {
      grid-template-columns: 58px minmax(0, 1fr);
      padding: 16px;
    }

    .avatar-wrap,
    img,
    .avatar {
      height: 58px;
      width: 58px;
    }
  }
</style>
