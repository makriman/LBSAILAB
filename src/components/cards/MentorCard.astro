---
import type { MentorEntry } from "@utils/collections";
import { initials } from "@utils/collections";

interface Props {
  mentor: MentorEntry;
}

const { mentor } = Astro.props;
---

<article class="mentor-card">
  {
    mentor.data.linkedinUrl ? (
      <a
        class="photo-link"
        href={mentor.data.linkedinUrl}
        aria-label={`Open ${mentor.data.name} on LinkedIn`}
        target="_blank"
        rel="noreferrer"
      >
        {mentor.data.image ? (
          <img
            src={mentor.data.image}
            alt={mentor.data.name}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <span class="avatar" aria-hidden="true">
            {initials(mentor.data.name)}
          </span>
        )}
      </a>
    ) : (
      <div class="photo-link">
        {mentor.data.image ? (
          <img
            src={mentor.data.image}
            alt={mentor.data.name}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <span class="avatar" aria-hidden="true">
            {initials(mentor.data.name)}
          </span>
        )}
      </div>
    )
  }
  <div class="mentor-body">
    <p class="mentor-type">{mentor.data.mentorType}</p>
    <h3>{mentor.data.name}</h3>
    {mentor.data.focus && <p class="mentor-focus">{mentor.data.focus}</p>}
    <div class="mentor-links">
      {
        mentor.data.showEmailPublicly && (
          <a class="connect-link" href={`mailto:${mentor.data.email}`}>
            Connect
          </a>
        )
      }
      {
        mentor.data.linkedinUrl && (
          <a
            class="linkedin-link"
            href={mentor.data.linkedinUrl}
            target="_blank"
            rel="noreferrer"
          >
            LinkedIn
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .mentor-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 100%;
  }

  .photo-link {
    background: var(--color-cloud);
    border-bottom: 1px solid var(--color-border);
    display: block;
    overflow: hidden;
    text-decoration: none;
  }

  img,
  .avatar {
    aspect-ratio: 1 / 1;
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  .avatar {
    align-items: center;
    background: var(--color-lbs-blue);
    color: var(--color-white);
    display: flex;
    font-size: var(--step-2);
    font-weight: 900;
    justify-content: center;
  }

  .mentor-body {
    display: grid;
    gap: 12px;
    grid-template-rows: auto auto 1fr auto;
    padding: 18px;
  }

  h3 {
    color: var(--color-lbs-blue);
    font-family: var(--font-sans);
    font-size: var(--step-1);
    line-height: 1.15;
    margin: 0;
  }

  .mentor-type {
    color: var(--color-lbs-red);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    margin: 0;
    text-transform: uppercase;
  }

  .mentor-focus {
    color: var(--color-ink-soft);
    font-size: 0.95rem;
    line-height: 1.42;
    margin: 0;
  }

  .mentor-links {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }

  .connect-link,
  .linkedin-link {
    align-items: center;
    display: inline-flex;
    font-size: var(--step--1);
    font-weight: 850;
    justify-content: center;
    min-height: 38px;
    padding: 9px 13px;
    text-decoration: none;
  }

  .connect-link {
    background: var(--color-lbs-blue);
    border-radius: var(--radius-button);
    color: var(--color-white);
  }

  .connect-link:hover {
    background: var(--color-lbs-red);
  }

  .linkedin-link {
    color: var(--color-lbs-blue);
    text-decoration: underline;
    text-decoration-color: rgba(205, 13, 47, 0.36);
  }

  @media (max-width: 420px) {
    .mentor-body {
      padding: 16px;
    }
  }
</style>
