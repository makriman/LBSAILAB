---
import type { TeamEntry } from "@utils/collections";

interface Props {
  team: TeamEntry;
  featured?: boolean;
}

const { team, featured = false } = Astro.props;
const builderNames = team.data.members.map((member) => member.name);
---

<article class:list={["team-card", { featured }]}>
  <div class="meta">
    <span>{team.data.cohortLabel}</span>
  </div>
  <div class="content">
    <h3>{team.data.displayName}</h3>
    <p>{team.data.tagline}</p>
    <ul class="builders" aria-label={`${team.data.displayName} builders`}>
      {builderNames.map((name) => <li>{name}</li>)}
    </ul>
  </div>
  <div class="footer">
    <div class="links">
      {
        team.data.productUrl && (
          <a href={team.data.productUrl} target="_blank" rel="noreferrer">
            Product
          </a>
        )
      }
      <a href={`/teams/${team.data.slug}/`}>Profile</a>
    </div>
  </div>
</article>

<style>
  .team-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: 0 0 0 rgba(20, 23, 93, 0);
    display: grid;
    gap: clamp(24px, 3vw, 34px);
    grid-template-rows: auto 1fr auto;
    height: 100%;
    min-height: 280px;
    padding: clamp(22px, 3vw, 30px);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .team-card:hover {
    border-color: var(--color-lbs-blue);
    box-shadow: var(--shadow-card);
    transform: translateY(-3px);
  }

  .team-card.featured {
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.6fr);
    min-height: 230px;
  }

  .meta {
    align-content: start;
    display: grid;
    gap: 8px;
  }

  .meta span {
    color: var(--color-muted);
    font-size: var(--step--1);
    font-weight: 780;
  }

  .content {
    align-content: start;
    display: grid;
    gap: 14px;
  }

  h3 {
    color: var(--color-lbs-blue);
    font-size: clamp(1.65rem, 2.25vw, 2.45rem);
    margin: 0;
    overflow-wrap: anywhere;
  }

  p {
    color: var(--color-ink-soft);
    line-height: 1.45;
  }

  .builders {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 4px 0 0;
    padding: 0;
  }

  .builders li {
    background: var(--color-cloud);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    color: var(--color-ink-soft);
    font-size: 0.76rem;
    font-weight: 780;
    line-height: 1.2;
    padding: 7px 10px;
  }

  .footer {
    align-self: end;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: space-between;
    padding-top: 18px;
  }

  .links {
    display: flex;
    gap: 14px;
  }

  .links a {
    color: var(--color-lbs-blue);
    font-size: var(--step--1);
    font-weight: 820;
    text-decoration: none;
  }

  .links a::after {
    color: var(--color-lbs-red);
    content: " ->";
  }

  @media (max-width: 760px) {
    .team-card.featured {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .team-card {
      gap: 18px;
      min-height: auto;
    }
  }
</style>
