---
import type { TeamEntry } from "@utils/collections";

interface Props {
  team: TeamEntry;
  basePath?: string;
}

const { team, basePath = "/batches/spring-2026" } = Astro.props;
const href = `${basePath}/${team.data.slug}/`;
const label = team.data.status.toLowerCase().includes("prototype")
  ? "Prototype"
  : team.data.status;
---

<a class="team-card" href={href}>
  <span class="status">{label}</span>
  <h3>{team.data.displayName}</h3>
  <p>{team.data.tagline}</p>
  <span class="team-link">View team</span>
</a>

<style>
  .team-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: grid;
    gap: 14px;
    min-height: 220px;
    padding: clamp(20px, 3vw, 26px);
    text-decoration: none;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .team-card:hover {
    border-color: var(--color-lbs-blue);
    box-shadow: var(--shadow-card);
    transform: translateY(-2px);
  }

  .status {
    color: var(--color-lbs-red);
    font-size: var(--step--1);
    font-weight: 860;
  }

  h3 {
    color: var(--color-lbs-blue);
    font-family: var(--font-sans);
    font-size: var(--step-1);
    line-height: 1.1;
    margin: 0;
    overflow-wrap: anywhere;
  }

  p {
    color: var(--color-ink-soft);
    font-size: 0.98rem;
    line-height: 1.45;
    margin: 0;
  }

  .team-link {
    align-self: end;
    border-top: 1px solid var(--color-border);
    color: var(--color-lbs-blue);
    font-size: var(--step--1);
    font-weight: 860;
    margin-top: 12px;
    padding-top: 14px;
  }

  .team-link::after {
    color: var(--color-lbs-red);
    content: " ->";
  }
</style>
