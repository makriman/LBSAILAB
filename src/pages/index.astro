---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/atoms/Button.astro";
import SectionHeader from "@components/atoms/SectionHeader.astro";
import GoogleDeepMindLogo from "@components/brand/GoogleDeepMindLogo.astro";
import DirectorCard from "@components/cards/DirectorCard.astro";
import TeamGrid from "@components/sections/TeamGrid.astro";
import MentorGrid from "@components/sections/MentorGrid.astro";
import ApplyCTA from "@components/sections/ApplyCTA.astro";
import { LBS_URL, SITE_URL } from "@utils/site";
import { sortTeamsByBatchList } from "@utils/collections";

const [teams, batches, mentors] = await Promise.all([
  getCollection("teams"),
  getCollection("batches"),
  getCollection("mentors"),
]);

const springBatch = batches.find((batch) => batch.data.id === "spring-2026");
const springTeams = springBatch
  ? sortTeamsByBatchList(
      teams.filter((team) => team.data.batch === springBatch.data.id),
      springBatch.data.teams,
    )
  : teams;

const previewTeams = springTeams.slice(0, 6);
const hasGoogleDeepMindPartner =
  springBatch?.data.partnerName === "Google DeepMind";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  name: "LBS AI Lab",
  parentOrganization: {
    "@type": "CollegeOrUniversity",
    name: "London Business School",
    url: LBS_URL,
  },
  url: `${SITE_URL}/`,
  description:
    "A hands-on AI lab where London Business School participants build AI products for LBS workflows",
};
---

<BaseLayout
  title="LBS AI Lab | Build AI products for LBS"
  description="LBS AI Lab helps participants build AI products for LBS workflows through an 8-week batch model"
  jsonLd={jsonLd}
>
  <section class="home-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">
          London Business School / Data Science & AI Initiative
        </p>
        <h1>Build AI products for LBS</h1>
        <p class="lede">
          A hands-on lab where participants turn LBS workflows into useful AI
          products through an 8-week batch model
        </p>
        {
          hasGoogleDeepMindPartner && (
            <div class="hero-partner">
              <GoogleDeepMindLogo
                label="Spring 2026 Batch in partnership with"
                compact
              />
            </div>
          )
        }
        <div class="hero-actions">
          <Button href="/apply/">Join the next batch</Button>
          <Button href="/batches/spring-2026/" variant="secondary">
            View Spring 2026 Batch
          </Button>
        </div>
      </div>
      <div class="hero-media" aria-label="LBS AI Lab batch context">
        <div class="hero-image">
          <img
            src="/images/lbs-ai-lab-workshop-hero.png"
            alt="Participants collaborating in a product sprint workshop"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="hero-note">
          <p class="eyebrow">Spring 2026 Batch</p>
          <p>
            Nine teams are building AI products for LBS workflows through an
            8-week cycle of discovery, development, evaluation, and iteration
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section learn-section">
    <div class="container">
      <SectionHeader
        title="What participants learn in the Lab"
        body="Participants develop the product, technical, and leadership skills needed to build AI products from problem discovery to launch"
      />
      <div class="learn-grid">
        <article>
          <h3>Define the problem</h3>
          <p>Turn ambiguous workflows into clear product opportunities</p>
        </article>
        <article>
          <h3>Understand the user</h3>
          <p>
            Run interviews, map needs, and identify where AI can create value
          </p>
        </article>
        <article>
          <h3>Manage stakeholders</h3>
          <p>
            Work with participants, alumni, clubs, staff, and partners to
            navigate constraints and adoption
          </p>
        </article>
        <article>
          <h3>Build with AI</h3>
          <p>Use AI-assisted tools to prototype and ship quickly</p>
        </article>
        <article>
          <h3>Evaluate and iterate</h3>
          <p>Test quality, learn from feedback, and improve the product</p>
        </article>
        <article>
          <h3>Think toward product-market fit</h3>
          <p>
            Move from a promising demo to something people understand, adopt,
            and return to
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-warm batch-preview">
    <div class="container section-split">
      <div class="batch-intro">
        <SectionHeader
          eyebrow="Spring 2026 Batch"
          title="Nine teams building AI products for LBS workflows"
          body="Nine teams joined the first LBS AI Lab batch to build AI products for LBS workflows"
        />
        {
          hasGoogleDeepMindPartner && (
            <GoogleDeepMindLogo label="In partnership with" compact />
          )
        }
      </div>
      <Button href="/batches/spring-2026/" variant="secondary">
        View Spring 2026 Batch
      </Button>
    </div>
    <div class="container team-preview">
      <TeamGrid teams={previewTeams} />
    </div>
  </section>

  <section class="section mentor-preview">
    <div class="container section-split">
      <SectionHeader
        eyebrow="Mentors"
        title="Guidance from product and technical mentors"
        body="Teams are supported by product and technical mentors through build sessions, product reviews, implementation guidance, and feedback cycles"
      />
      <Button href="/mentors/" variant="secondary">Meet the mentors</Button>
    </div>
    <div class="container academic-preview">
      <p class="eyebrow">Academic lead</p>
      <DirectorCard />
    </div>
    <div class="container mentor-list">
      <MentorGrid mentors={mentors} />
    </div>
  </section>

  <ApplyCTA />
</BaseLayout>

<style>
  .home-hero {
    background: var(--color-warm-white);
    border-bottom: 1px solid var(--color-border);
    padding-block: clamp(42px, 6vw, 74px);
  }

  .hero-grid {
    align-items: stretch;
    display: grid;
    gap: clamp(34px, 5vw, 70px);
    grid-template-columns: minmax(0, 0.95fr) minmax(380px, 0.88fr);
  }

  .hero-copy h1 {
    color: var(--color-lbs-blue);
    font-size: clamp(3rem, 5vw, 5.2rem);
    letter-spacing: 0;
    line-height: 0.93;
    margin: 18px 0 20px;
    max-width: 760px;
  }

  .hero-copy .lede {
    color: var(--color-ink-soft);
    font-size: clamp(1.18rem, 1.02rem + 0.62vw, 1.52rem);
    line-height: 1.45;
    max-width: 640px;
  }

  .hero-partner {
    background: var(--color-white);
    border-left: 3px solid var(--color-lbs-red);
    display: inline-block;
    margin-top: 26px;
    padding: 16px 18px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .hero-media {
    align-self: center;
    display: grid;
    gap: 18px;
  }

  .hero-image {
    border: 1px solid var(--color-border);
    min-height: 0;
    overflow: hidden;
  }

  .hero-image img {
    aspect-ratio: 4 / 3;
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  .hero-note {
    border-top: 2px solid var(--color-lbs-red);
    display: grid;
    gap: 8px;
    padding-top: 16px;
  }

  .hero-note .eyebrow {
    margin: 0;
  }

  .hero-note p:not(.eyebrow) {
    color: var(--color-ink-soft);
    font-size: var(--step-0);
    line-height: 1.45;
    margin: 0;
    max-width: 620px;
  }

  .learn-grid {
    display: grid;
    gap: 0;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 38px;
  }

  .learn-grid article {
    border-top: 1px solid var(--color-border);
    display: grid;
    gap: 10px;
    padding: 22px 22px 22px 0;
  }

  .learn-grid article:nth-child(odd) {
    border-right: 1px solid var(--color-border);
    padding-right: 26px;
  }

  .learn-grid article:nth-child(even) {
    padding-left: 26px;
  }

  .learn-grid h3 {
    color: var(--color-lbs-blue);
    font-family: var(--font-sans);
    font-size: var(--step-0);
    margin: 0;
  }

  .learn-grid p {
    color: var(--color-ink-soft);
    margin: 0;
  }

  .section-split {
    align-items: end;
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .batch-intro {
    display: grid;
    gap: 22px;
  }

  .team-preview,
  .academic-preview,
  .mentor-list {
    margin-top: 34px;
  }

  .academic-preview .eyebrow {
    margin-bottom: 14px;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .section-split {
      grid-template-columns: 1fr;
    }

    .section-split :global(.button) {
      justify-self: start;
    }

    .hero-copy h1 {
      max-width: 680px;
    }
  }

  @media (max-width: 520px) {
    .hero-copy h1 {
      font-size: clamp(2.55rem, 13vw, 3.55rem);
    }

    .hero-partner {
      display: block;
      padding: 14px 15px;
    }

    .hero-image img {
      aspect-ratio: 5 / 4;
    }
  }

  @media (max-width: 680px) {
    .learn-grid {
      grid-template-columns: 1fr;
    }

    .learn-grid article:nth-child(odd),
    .learn-grid article:nth-child(even) {
      border-left: 0;
      border-right: 0;
      padding-left: 0;
      padding-right: 0;
    }
  }
</style>
