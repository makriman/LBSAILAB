---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/atoms/Button.astro";
import SectionHeader from "@components/atoms/SectionHeader.astro";
import TeamGrid from "@components/sections/TeamGrid.astro";
import MentorGrid from "@components/sections/MentorGrid.astro";
import ApplyCTA from "@components/sections/ApplyCTA.astro";
import { LBS_URL, SITE_URL } from "@utils/site";
import { sortTeamsByBatchList } from "@utils/collections";

const [teams, batches, mentors] = await Promise.all([
  getCollection("teams"),
  getCollection("batches"),
  getCollection("mentors"),
]);

const springBatch = batches.find((batch) => batch.data.id === "spring-2026");
const springTeams = springBatch
  ? sortTeamsByBatchList(
      teams.filter((team) => team.data.batch === springBatch.data.id),
      springBatch.data.teams,
    )
  : teams;

const previewTeams = springTeams.slice(0, 6);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  name: "LBS AI Lab",
  parentOrganization: {
    "@type": "CollegeOrUniversity",
    name: "London Business School",
    url: LBS_URL,
  },
  url: `${SITE_URL}/`,
  description:
    "A hands-on AI lab where London Business School participants build AI products for LBS workflows",
};
---

<BaseLayout
  title="LBS AI Lab | Helping leaders become AI builders"
  description="LBS AI Lab helps participants learn to build, test, and launch AI products with users"
  jsonLd={jsonLd}
>
  <section class="home-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">
          London Business School / Data Science & AI Initiative
        </p>
        <h1>Helping the next generation of leaders become AI builders</h1>
        <p class="lede">
          LBS AI Lab is where participants learn to build, test, and launch AI
          products with users
        </p>
        <div class="hero-actions">
          <Button href="/apply/" size="lg">Join the next batch</Button>
          <Button href="/batches/spring-2026/" variant="secondary" size="lg">
            View Spring 2026 Batch
          </Button>
        </div>
      </div>
      <div class="hero-image">
        <img
          src="/images/lbs-ai-lab-workshop-hero.png"
          alt="Participants collaborating in a product sprint workshop"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <section class="proof-section" aria-label="Spring 2026 Batch facts">
    <div class="container proof-stats">
      <div>
        <strong>9</strong>
        <span>teams</span>
      </div>
      <div>
        <strong>22</strong>
        <span>builders</span>
      </div>
      <div>
        <strong>4</strong>
        <span>mentors</span>
      </div>
      <div>
        <strong>8</strong>
        <span>weeks</span>
      </div>
    </div>
  </section>

  <section class="section learn-section">
    <div class="container">
      <SectionHeader
        title="What participants learn in the Lab"
        body="Participants develop the product, technical, and leadership skills needed to build AI products from problem discovery to launch"
      />
      <div class="learn-grid">
        <article>
          <h3>Define the problem</h3>
          <p>Turn ambiguous workflows into clear product opportunities</p>
        </article>
        <article>
          <h3>Understand the user</h3>
          <p>
            Run interviews, map needs, and identify where AI can create value
          </p>
        </article>
        <article>
          <h3>Manage stakeholders</h3>
          <p>
            Work with participants, alumni, clubs, staff, and partners to
            navigate constraints and adoption
          </p>
        </article>
        <article>
          <h3>Build with AI</h3>
          <p>Use AI-assisted tools to prototype and ship quickly</p>
        </article>
        <article>
          <h3>Evaluate and iterate</h3>
          <p>Test quality, learn from feedback, and improve the product</p>
        </article>
        <article>
          <h3>Think toward product-market fit</h3>
          <p>
            Move from a promising demo to something people understand, adopt,
            and return to
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-warm batch-preview">
    <div class="container section-split">
      <SectionHeader
        eyebrow="Spring 2026 Batch"
        title="Nine teams building AI products for LBS workflows"
        body="Nine teams joined the first LBS AI Lab batch to build AI products for LBS workflows"
      />
      <Button href="/batches/spring-2026/" variant="secondary">
        View Spring 2026 Batch
      </Button>
    </div>
    <div class="container team-preview">
      <TeamGrid teams={previewTeams} />
    </div>
  </section>

  <section class="section mentor-preview">
    <div class="container section-split">
      <SectionHeader
        eyebrow="Mentors"
        title="Guidance from product and technical mentors"
        body="Teams are supported by product and technical mentors through build sessions, product reviews, implementation guidance, and feedback cycles"
      />
      <Button href="/mentors/" variant="secondary">Meet the mentors</Button>
    </div>
    <div class="container mentor-list">
      <MentorGrid mentors={mentors} />
    </div>
  </section>

  <ApplyCTA />
</BaseLayout>

<style>
  .home-hero {
    background: var(--color-warm-white);
    border-bottom: 1px solid var(--color-border);
    padding-block: clamp(44px, 7vw, 86px);
  }

  .hero-grid {
    align-items: center;
    display: grid;
    gap: clamp(34px, 6vw, 76px);
    grid-template-columns: minmax(0, 0.92fr) minmax(360px, 1fr);
  }

  .hero-copy h1 {
    color: var(--color-lbs-blue);
    font-size: clamp(2.8rem, 5.6vw, 5.1rem);
    margin: 18px 0;
    max-width: 780px;
  }

  .hero-copy .lede {
    color: var(--color-ink-soft);
    max-width: 620px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }

  .hero-image {
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .hero-image img {
    aspect-ratio: 16 / 9;
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  .proof-section {
    background: var(--color-white);
    padding-block: clamp(18px, 4vw, 34px);
  }

  .proof-stats {
    border-block: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .proof-stats div {
    border-left: 1px solid var(--color-border);
    display: grid;
    gap: 6px;
    padding: 16px;
  }

  .proof-stats div:first-child {
    border-left: 0;
  }

  .proof-stats strong {
    color: var(--color-lbs-blue);
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.8rem);
    line-height: 0.95;
  }

  .proof-stats span {
    color: var(--color-muted);
    font-size: var(--step--1);
    font-weight: 820;
  }

  .learn-grid {
    display: grid;
    gap: 0;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 38px;
  }

  .learn-grid article {
    border-top: 1px solid var(--color-border);
    display: grid;
    gap: 10px;
    padding: 22px 22px 22px 0;
  }

  .learn-grid article:nth-child(odd) {
    border-right: 1px solid var(--color-border);
    padding-right: 26px;
  }

  .learn-grid article:nth-child(even) {
    padding-left: 26px;
  }

  .learn-grid h3 {
    color: var(--color-lbs-blue);
    font-family: var(--font-sans);
    font-size: var(--step-0);
    margin: 0;
  }

  .learn-grid p {
    color: var(--color-ink-soft);
    margin: 0;
  }

  .section-split {
    align-items: end;
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .team-preview,
  .mentor-list {
    margin-top: 34px;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .section-split {
      grid-template-columns: 1fr;
    }

    .section-split :global(.button) {
      justify-self: start;
    }
  }

  @media (max-width: 680px) {
    .proof-stats,
    .learn-grid {
      grid-template-columns: 1fr;
    }

    .proof-stats div,
    .proof-stats div:first-child,
    .learn-grid article:nth-child(odd),
    .learn-grid article:nth-child(even) {
      border-left: 0;
      border-right: 0;
      padding-left: 0;
      padding-right: 0;
    }

    .proof-stats div + div {
      border-top: 1px solid var(--color-border);
    }
  }
</style>
