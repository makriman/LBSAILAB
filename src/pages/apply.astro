---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/atoms/Button.astro";

const registerInterestEmail = "rlokanathan.mba2027@london.edu";
---

<BaseLayout
  title="Apply"
  description="Register interest for the September 2026 LBS AI Lab cohort and learn to build AI products with real LBS users."
>
  <section class="page-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Apply</p>
        <h1>Build with AI. Learn from real users.</h1>
        <p class="lede">
          The September 2026 cohort is for LBS students who want to prototype
          fast, test with students and alumni, and improve from feedback.
        </p>
        <Button
          href="#register-interest"
          variant="red"
          size="lg"
          external={false}
        >
          Register interest for September 2026
        </Button>
      </div>
      <aside>
        <span>Cohort 02</span>
        <strong>September 2026</strong>
        <ul>
          <li>Build with AI-assisted tools</li>
          <li>Test with real LBS users</li>
          <li>Iterate with mentor support</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section section-warm" id="register-interest">
    <div class="container form-grid">
      <div>
        <p class="eyebrow">Register interest</p>
        <h2>Tell us who you are.</h2>
        <p>
          Share your LBS details for the September 2026 cohort list. The Lab
          team will follow up when applications open and sessions are announced.
        </p>
      </div>

      <form
        class="interest-form"
        action={`mailto:${registerInterestEmail}?subject=LBS%20AI%20Lab%20September%202026%20interest`}
        method="post"
        enctype="text/plain"
      >
        <label>
          <span>Name</span>
          <input name="name" autocomplete="name" required />
        </label>
        <label>
          <span>LBS email</span>
          <input
            name="lbs_email"
            type="email"
            autocomplete="email"
            pattern={"^[^@\\s]+@london\\.edu$"}
            placeholder="name.program@london.edu"
            required
          />
        </label>
        <label>
          <span>Course name</span>
          <input
            name="course_name"
            autocomplete="organization-title"
            placeholder="MBA, MiF, MAM..."
            required
          />
        </label>
        <label>
          <span>What would you like to build?</span>
          <textarea name="build_interest" rows="4"></textarea>
        </label>
        <button type="submit">Submit interest</button>
      </form>
    </div>
  </section>

  <section class="section">
    <div class="container apply-grid">
      <section>
        <p class="eyebrow">Who this is for</p>
        <h2>Students who want to learn how to build something people want.</h2>
        <ul>
          <li>LBS students with a product idea.</li>
          <li>Operators who see a workflow that can be made better with AI.</li>
          <li>Future founders looking for co-builders and early users.</li>
          <li>
            Students who want practical AI fluency beyond classroom learning.
          </li>
        </ul>
      </section>

      <section>
        <p class="eyebrow">What you will do</p>
        <h2>Move from problem to prototype to user feedback.</h2>
        <ul>
          <li>Form or join a team.</li>
          <li>Choose a real LBS use case.</li>
          <li>Prototype with AI-assisted tools.</li>
          <li>Test with LBS students and alumni.</li>
          <li>Improve based on feedback.</li>
          <li>Work with mentors.</li>
          <li>Demo what you build.</li>
        </ul>
      </section>

      <section>
        <p class="eyebrow">What you do not need</p>
        <h2>You do not need to be a professional software engineer.</h2>
        <p>
          You do need curiosity, discipline, and willingness to learn by
          shipping. The Lab is practical, team-based, and focused on the real
          product loop.
        </p>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(52px, 7vw, 92px);
  }

  .hero-grid {
    align-items: center;
    display: grid;
    gap: clamp(34px, 6vw, 80px);
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
  }

  .hero-grid > * {
    min-width: 0;
  }

  :global(.page-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  h1 {
    color: var(--color-white);
    margin: 20px 0;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    margin-bottom: 30px;
    max-width: 820px;
  }

  aside {
    border: 1px solid rgba(255, 255, 255, 0.22);
    padding: 28px;
  }

  aside span {
    color: rgba(255, 255, 255, 0.65);
    font-weight: 820;
  }

  aside strong {
    display: block;
    font-family: var(--font-serif);
    font-size: var(--step-2);
    line-height: 1;
    margin: 14px 0;
  }

  aside ul {
    display: grid;
    gap: 10px;
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
  }

  aside li {
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.72);
    font-weight: 760;
    padding-top: 10px;
  }

  .apply-grid {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .apply-grid section {
    border: 1px solid var(--color-border);
    display: grid;
    gap: 14px;
    grid-template-rows: auto minmax(5.8rem, auto) 1fr;
    padding: clamp(24px, 4vw, 34px);
  }

  .apply-grid h2 {
    color: var(--color-lbs-blue);
    font-size: var(--step-2);
    margin: 16px 0;
  }

  .apply-grid p:not(.eyebrow),
  li {
    color: var(--color-ink-soft);
  }

  .apply-grid ul {
    display: grid;
    gap: 10px;
    margin: 0;
    padding-left: 19px;
  }

  .form-grid {
    align-items: start;
    display: grid;
    gap: clamp(28px, 5vw, 70px);
    grid-template-columns: minmax(0, 0.58fr) minmax(320px, 0.72fr);
  }

  .form-grid h2 {
    color: var(--color-lbs-blue);
    margin: 16px 0;
  }

  .form-grid p:not(.eyebrow) {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
  }

  .interest-form {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: grid;
    gap: 18px;
    padding: clamp(22px, 4vw, 36px);
  }

  label {
    display: grid;
    gap: 8px;
  }

  label span {
    color: var(--color-lbs-blue);
    font-size: var(--step--1);
    font-weight: 820;
  }

  input,
  textarea {
    background: var(--color-white);
    border: 1px solid var(--color-border-strong);
    border-radius: 0;
    color: var(--color-ink);
    min-height: 48px;
    padding: 12px 14px;
    width: 100%;
  }

  textarea {
    min-height: 120px;
    resize: vertical;
  }

  button {
    background: var(--color-lbs-red);
    border: 0;
    border-radius: var(--radius-button);
    color: var(--color-white);
    cursor: pointer;
    font-weight: 850;
    min-height: 52px;
    padding: 14px 22px;
  }

  @media (max-width: 940px) {
    .hero-grid,
    .apply-grid,
    .form-grid {
      grid-template-columns: 1fr;
    }

    .apply-grid section {
      grid-template-rows: auto;
    }
  }

  @media (max-width: 520px) {
    .page-hero {
      padding-block: 42px 48px;
    }

    aside {
      padding: 20px;
    }
  }
</style>
