---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/atoms/Button.astro";
import { pageJsonLd } from "@utils/seo";

const pageTitle = "Join the next batch";
const pageDescription =
  "Register interest for the Autumn 2026 Batch of LBS AI Lab";
const jsonLd = pageJsonLd({
  title: pageTitle,
  description: pageDescription,
  path: "/apply/",
  breadcrumbs: [
    { name: "LBS AI Lab", path: "/" },
    { name: "Join the next batch", path: "/apply/" },
  ],
});
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <section class="page-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Autumn 2026 Batch</p>
        <h1>Join the next batch</h1>
        <p class="lede">
          Autumn 2026 Batch opens in September 2026 for participants ready to
          build AI products for LBS workflows
        </p>
        <div class="hero-actions">
          <Button
            href="#register-interest"
            variant="red"
            size="lg"
            external={false}
          >
            Join the next batch
          </Button>
          <Button
            href="#submissions"
            variant="ghost"
            size="lg"
            external={false}
          >
            View submissions
          </Button>
        </div>
      </div>

      <aside class="hero-card" aria-label="Batch process">
        <span>Batch loop</span>
        <ol>
          <li>
            <strong>01</strong>
            <p>Choose an LBS workflow</p>
          </li>
          <li>
            <strong>02</strong>
            <p>Build an AI prototype</p>
          </li>
          <li>
            <strong>03</strong>
            <p>Test with users and iterate</p>
          </li>
        </ol>
      </aside>

      <div class="hero-proof" aria-label="Batch signals">
        <span>For the LBS community</span>
        <span>LBS workflows</span>
        <span>Participant and alumni feedback</span>
        <span>Mentor support</span>
      </div>
    </div>
  </section>

  <section class="section section-warm" id="register-interest">
    <div class="container form-grid">
      <div>
        <p class="eyebrow">Join the next batch</p>
        <h2>Tell us who you are</h2>
        <p>
          Share your LBS details for the Autumn 2026 Batch list. The Lab team
          will follow up when applications open and sessions are announced.
        </p>
        <ul class="next-steps">
          <li>Submit with or without a formed team</li>
          <li>Opt in publicly if you want other builders to find you</li>
          <li>Use the submissions list below to find potential co-builders</li>
        </ul>
      </div>

      <form class="interest-form" data-application-form>
        <label>
          <span>Name</span>
          <input name="name" autocomplete="name" required />
        </label>
        <label>
          <span>LBS email</span>
          <input
            name="lbs_email"
            type="email"
            autocomplete="email"
            pattern={"^[^@\\s]+@london\\.edu$"}
            placeholder="name.program@london.edu"
            required
          />
        </label>
        <label>
          <span>Course name</span>
          <input
            name="course_name"
            autocomplete="organization-title"
            placeholder="MBA, MiF, MAM..."
            required
          />
        </label>
        <label>
          <span>What would you like to build?</span>
          <textarea name="build_interest" rows="4" maxlength="900" required
          ></textarea>
        </label>
        <label class="consent-field">
          <input name="public_consent" type="checkbox" value="yes" required />
          <span>
            Show my name, course, and idea on this page so other LBS builders
            can contact me about working together
          </span>
        </label>
        <label class="bot-field" aria-hidden="true">
          <span>Website</span>
          <input name="website" tabindex="-1" autocomplete="off" />
        </label>
        <p class="form-status" data-form-status role="status"></p>
        <button type="submit">Submit interest</button>
      </form>
    </div>
  </section>

  <section class="section fit-section">
    <div class="container fit-layout">
      <div class="fit-intro">
        <p class="eyebrow">Who should join</p>
        <h2>You do not need to be a professional software engineer</h2>
        <p>
          You do need curiosity, discipline, and willingness to learn by
          shipping. The Lab is practical, team-based, and focused on the product
          loop.
        </p>
      </div>

      <div class="fit-list">
        <section>
          <p class="eyebrow">Who this is for</p>
          <ul>
            <li>LBS participants with a product idea</li>
            <li>
              Operators who see a workflow that can be made better with AI
            </li>
            <li>Future founders looking for co-builders and early users</li>
            <li>
              Participants who want practical AI fluency beyond classroom
              learning
            </li>
          </ul>
        </section>

        <section>
          <p class="eyebrow">What you will do</p>
          <ul>
            <li>Form or join a team</li>
            <li>Choose an LBS workflow</li>
            <li>Prototype with AI-assisted tools</li>
            <li>Test with LBS participants and alumni</li>
            <li>Improve based on feedback</li>
            <li>Work with mentors</li>
            <li>Demo what you build</li>
          </ul>
        </section>

        <section>
          <p class="eyebrow">What you leave with</p>
          <ul>
            <li>A sharper problem statement</li>
            <li>A working AI product prototype</li>
            <li>Evidence from users</li>
            <li>People to keep building with</li>
          </ul>
        </section>
      </div>
    </div>
  </section>

  <section class="section submissions-section" id="submissions">
    <div class="container submissions-grid">
      <div>
        <p class="eyebrow">Find co-builders</p>
        <h2>See who is looking for people to build with</h2>
        <p>
          Participants who opt in can share their name, course, and build idea
          here. Use the contact button to start a conversation about working
          together.
        </p>
      </div>

      <div class="submissions-panel">
        <div class="submissions-top">
          <strong>Autumn 2026 submissions</strong>
        </div>
        <p
          class="submissions-status"
          data-submissions-status
          role="status"
          hidden
        >
        </p>
        <div class="submission-list" data-submission-list hidden></div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const form = document.querySelector("[data-application-form]");
  const formStatus = document.querySelector("[data-form-status]");
  const submissionsStatus = document.querySelector("[data-submissions-status]");
  const submissionsList = document.querySelector("[data-submission-list]");
  const IDEA_PREVIEW_LENGTH = 280;

  const setText = (node, text) => {
    if (node) {
      node.textContent = text;
    }
  };

  const setStatus = (text, hidden = false) => {
    if (submissionsStatus) {
      submissionsStatus.textContent = text;
      submissionsStatus.hidden = hidden;
    }
  };

  const contactHref = (application) => {
    const subject = `LBS AI Lab: exploring your ${application.course} build idea`;
    const body = `Hi ${application.name.split(" ")[0]},\n\nI saw your LBS AI Lab submission. Would you be open to chatting about working together?\n\n`;
    return `mailto:${application.email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  };

  const tableCell = (label, text) => {
    const cell = document.createElement("td");
    cell.dataset.label = label;
    cell.textContent = text;
    return cell;
  };

  const ideaText = (idea) =>
    String(idea || "")
      .replace(/\s+/g, " ")
      .trim();

  const ideaPreview = (idea) =>
    idea.length > IDEA_PREVIEW_LENGTH
      ? `${idea.slice(0, IDEA_PREVIEW_LENGTH - 3).trim()}...`
      : idea;

  const ideaCell = (application) => {
    const cell = document.createElement("td");
    const fullIdea = ideaText(application.idea);
    const text = document.createElement("span");

    cell.dataset.label = "Idea";
    cell.className = "submission-idea";
    text.className = "submission-idea-text";

    if (fullIdea.length <= IDEA_PREVIEW_LENGTH) {
      text.textContent = fullIdea;
      cell.append(text);
      return cell;
    }

    const toggle = document.createElement("button");
    toggle.type = "button";
    toggle.className = "idea-toggle";

    const setExpanded = (expanded) => {
      text.textContent = expanded ? fullIdea : ideaPreview(fullIdea);
      toggle.textContent = expanded ? "Show less" : "Read more";
      toggle.setAttribute("aria-expanded", String(expanded));
    };

    toggle.addEventListener("click", () => {
      setExpanded(toggle.getAttribute("aria-expanded") !== "true");
    });

    setExpanded(false);
    cell.append(text, toggle);
    return cell;
  };

  const renderSubmissions = (applications) => {
    if (!submissionsList) return;

    submissionsList.innerHTML = "";

    if (!applications.length) {
      submissionsList.hidden = true;
      setStatus(
        "No public submissions yet. Be the first to share a build idea",
      );
      return;
    }

    const wrapper = document.createElement("div");
    wrapper.className = "submissions-table-scroll";

    const table = document.createElement("table");
    table.className = "submissions-table";

    const thead = document.createElement("thead");
    const headerRow = document.createElement("tr");

    for (const label of ["Name", "Course", "Idea", ""]) {
      const header = document.createElement("th");
      header.scope = "col";
      if (!label) {
        header.setAttribute("aria-label", "Connect");
      }
      header.textContent = label;
      headerRow.append(header);
    }

    thead.append(headerRow);

    const tbody = document.createElement("tbody");

    for (const application of applications) {
      const row = document.createElement("tr");

      const name = tableCell("Name", application.name);
      name.className = "submission-name";

      const course = tableCell("Course", application.course);
      course.className = "submission-course";

      const idea = ideaCell(application);

      const action = document.createElement("td");
      action.className = "submission-action";

      const contact = document.createElement("a");
      contact.href = contactHref(application);
      contact.className = "connect-button";
      contact.textContent = "Connect";

      action.append(contact);
      row.append(name, course, idea, action);
      tbody.append(row);
    }

    table.append(thead, tbody);
    wrapper.append(table);
    submissionsList.append(wrapper);

    submissionsList.hidden = false;
    setStatus(
      `${applications.length} public submission${applications.length === 1 ? "" : "s"} found.`,
    );
  };

  const loadSubmissions = async () => {
    if (!submissionsList) return;

    setStatus("", true);

    try {
      const response = await fetch("/api/applications", {
        headers: { Accept: "application/json" },
      });
      const data = response.headers
        .get("Content-Type")
        ?.includes("application/json")
        ? await response.json()
        : {};

      if (!response.ok) {
        throw new Error(data.error || "Submissions are not available yet.");
      }

      if (data.error) {
        throw new Error("Submissions are not available yet.");
      }

      renderSubmissions(data.applications || []);
    } catch (error) {
      submissionsList.hidden = true;
      setStatus(
        error instanceof Error
          ? error.message
          : "Submissions are not available yet.",
      );
    }
  };

  loadSubmissions();

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const submitButton = form.querySelector('button[type="submit"]');
    const payload = Object.fromEntries(new FormData(form).entries());

    setText(formStatus, "Submitting...");
    submitButton?.setAttribute("disabled", "true");

    try {
      const response = await fetch("/api/applications", {
        method: "POST",
        headers: {
          Accept: "application/json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });
      const data = response.headers
        .get("Content-Type")
        ?.includes("application/json")
        ? await response.json()
        : {};

      if (!response.ok) {
        throw new Error(data.error || "Submission failed.");
      }

      form.reset();
      setText(
        formStatus,
        "Submitted. Your idea will appear below once the public log updates.",
      );
      await loadSubmissions();
    } catch (error) {
      setText(
        formStatus,
        error instanceof Error
          ? error.message
          : "Submission failed. Please try again.",
      );
    } finally {
      submitButton?.removeAttribute("disabled");
    }
  });
</script>

<style>
  .page-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(44px, 5.4vw, 76px);
  }

  #register-interest,
  #submissions {
    scroll-margin-top: 104px;
  }

  .hero-grid {
    align-items: center;
    column-gap: clamp(26px, 4vw, 46px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.36fr);
    row-gap: clamp(24px, 3vw, 38px);
  }

  .hero-grid > * {
    min-width: 0;
  }

  .hero-copy {
    max-width: 820px;
  }

  :global(.page-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  h1 {
    color: var(--color-white);
    font-size: clamp(3rem, 4.05vw, 4.1rem);
    line-height: 0.98;
    margin: 18px 0;
    max-width: 820px;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(1.32rem, 2vw, 1.7rem);
    line-height: 1.35;
    margin-bottom: 0;
    max-width: 760px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .hero-card {
    background: rgba(255, 255, 255, 0.045);
    border-left: 4px solid var(--color-lbs-red);
    display: grid;
    gap: 20px;
    padding: clamp(22px, 3vw, 30px);
  }

  .hero-card span {
    color: rgba(255, 255, 255, 0.65);
    font-size: var(--step--1);
    font-weight: 820;
    text-transform: uppercase;
  }

  .hero-card ol {
    display: grid;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hero-card li {
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    display: grid;
    gap: 16px;
    grid-template-columns: 42px minmax(0, 1fr);
    padding-block: 15px;
  }

  .hero-card li:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
  }

  .hero-card strong {
    color: var(--color-lbs-red);
    font-weight: 900;
  }

  .hero-card p {
    color: rgba(255, 255, 255, 0.82);
    font-weight: 780;
    line-height: 1.32;
    margin: 0;
  }

  .hero-proof {
    border-block: 1px solid rgba(255, 255, 255, 0.16);
    display: grid;
    gap: 0;
    grid-column: 1 / -1;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .hero-proof span {
    color: rgba(255, 255, 255, 0.76);
    font-size: var(--step--1);
    font-weight: 830;
    line-height: 1.2;
    padding: 13px 16px;
  }

  .hero-proof span + span {
    border-left: 1px solid rgba(255, 255, 255, 0.16);
  }

  .fit-section {
    background: var(--color-white);
  }

  .fit-layout {
    display: grid;
    gap: clamp(28px, 6vw, 74px);
    grid-template-columns: minmax(0, 0.55fr) minmax(0, 1fr);
  }

  .fit-intro h2 {
    color: var(--color-lbs-blue);
    margin: 16px 0;
  }

  .fit-intro p:not(.eyebrow) {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
    line-height: 1.42;
  }

  .fit-list {
    border-top: 1px solid var(--color-border);
    display: grid;
    gap: 0;
  }

  .fit-list section {
    border-bottom: 1px solid var(--color-border);
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(180px, 0.32fr) minmax(0, 1fr);
    padding-block: 20px;
  }

  .fit-list :global(.eyebrow) {
    align-self: start;
  }

  .fit-list ul {
    columns: 2;
    column-gap: 34px;
    margin: 0;
    padding-left: 18px;
  }

  .fit-list li {
    color: var(--color-ink-soft);
    break-inside: avoid;
    font-weight: 720;
    line-height: 1.36;
    margin-bottom: 10px;
  }

  .fit-list li:last-child {
    margin-bottom: 0;
  }

  .form-grid {
    align-items: start;
    display: grid;
    gap: clamp(28px, 5vw, 70px);
    grid-template-columns: minmax(0, 0.58fr) minmax(320px, 0.72fr);
  }

  .form-grid h2 {
    color: var(--color-lbs-blue);
    margin: 16px 0;
  }

  .form-grid p:not(.eyebrow) {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
  }

  .next-steps {
    border-block: 1px solid var(--color-border);
    display: grid;
    gap: 0;
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
  }

  .next-steps li {
    border-top: 1px solid var(--color-border);
    color: var(--color-lbs-blue);
    font-weight: 790;
    line-height: 1.35;
    padding-block: 14px;
  }

  .next-steps li:first-child {
    border-top: 0;
  }

  .interest-form {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: grid;
    gap: 18px;
    padding: clamp(22px, 4vw, 36px);
  }

  label {
    display: grid;
    gap: 8px;
  }

  label span {
    color: var(--color-lbs-blue);
    font-size: var(--step--1);
    font-weight: 820;
  }

  .consent-field {
    align-items: start;
    display: grid;
    gap: 12px;
    grid-template-columns: 20px 1fr;
  }

  .consent-field input {
    margin-top: 3px;
    min-height: 20px;
    padding: 0;
    width: 20px;
  }

  .consent-field span {
    color: var(--color-ink-soft);
    font-size: 0.9rem;
    font-weight: 760;
    line-height: 1.45;
  }

  .bot-field {
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    height: 1px;
    overflow: hidden;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  input,
  textarea {
    background: var(--color-white);
    border: 1px solid var(--color-border-strong);
    border-radius: 0;
    color: var(--color-ink);
    min-height: 48px;
    padding: 12px 14px;
    width: 100%;
  }

  textarea {
    min-height: 120px;
    resize: vertical;
  }

  button {
    background: var(--color-lbs-red);
    border: 0;
    border-radius: var(--radius-button);
    color: var(--color-white);
    cursor: pointer;
    font-weight: 850;
    min-height: 52px;
    padding: 14px 22px;
  }

  button:disabled {
    cursor: wait;
    opacity: 0.66;
  }

  .form-status {
    color: var(--color-ink-soft);
    font-size: var(--step--1);
    font-weight: 760;
    min-height: 1.4em;
  }

  .submissions-section {
    background: var(--color-white);
  }

  .submissions-grid {
    align-items: start;
    display: grid;
    gap: clamp(24px, 4vw, 42px);
    grid-template-columns: 1fr;
  }

  .submissions-grid h2 {
    color: var(--color-lbs-blue);
    margin: 16px 0;
  }

  .submissions-grid > div:first-child {
    max-width: 820px;
  }

  .submissions-grid p:not(.eyebrow) {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
  }

  .submissions-panel {
    background: var(--color-warm-white);
    border: 1px solid var(--color-border);
    display: grid;
    gap: 18px;
    padding: clamp(20px, 3vw, 30px);
  }

  .submissions-top {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: space-between;
  }

  .submissions-top strong {
    color: var(--color-lbs-blue);
    font-size: var(--step-1);
  }

  .submissions-status {
    color: var(--color-muted);
    font-size: var(--step--1) !important;
    font-weight: 760;
  }

  .submission-list {
    overflow: hidden;
  }

  :global(.submissions-table-scroll) {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    overflow-x: auto;
  }

  :global(.submissions-table) {
    border-collapse: collapse;
    color: var(--color-ink);
    min-width: 720px;
    table-layout: fixed;
    width: 100%;
  }

  :global(.submissions-table th),
  :global(.submissions-table td) {
    border-bottom: 1px solid var(--color-border);
    padding: 16px 18px;
    text-align: left;
    vertical-align: top;
  }

  :global(.submissions-table th) {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    font-size: var(--step--1);
    font-weight: 820;
    letter-spacing: 0;
  }

  :global(.submissions-table td) {
    color: var(--color-ink-soft);
    font-size: 0.98rem;
    line-height: 1.42;
  }

  :global(.submissions-table tbody tr:last-child td) {
    border-bottom: 0;
  }

  :global(.submissions-table th:nth-child(1)),
  :global(.submissions-table td:nth-child(1)) {
    width: 22%;
  }

  :global(.submissions-table th:nth-child(2)),
  :global(.submissions-table td:nth-child(2)) {
    width: 15%;
  }

  :global(.submissions-table th:nth-child(4)),
  :global(.submissions-table td:nth-child(4)) {
    width: 24%;
  }

  :global(.submission-name) {
    color: var(--color-lbs-blue) !important;
    font-weight: 850;
  }

  :global(.submission-course) {
    color: var(--color-lbs-red) !important;
    font-weight: 820;
  }

  :global(.submission-idea) {
    overflow-wrap: anywhere;
  }

  :global(.submission-idea-text) {
    display: block;
  }

  :global(.idea-toggle) {
    background: transparent;
    border: 0;
    border-radius: 0;
    color: var(--color-lbs-blue);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 850;
    line-height: 1.1;
    margin-top: 10px;
    min-height: 0;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 3px;
    width: auto;
  }

  :global(.idea-toggle:hover),
  :global(.idea-toggle:focus-visible) {
    background: transparent;
    color: var(--color-lbs-red);
  }

  :global(.connect-button) {
    align-items: center;
    background: var(--color-lbs-blue);
    border-radius: var(--radius-button);
    color: var(--color-white);
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 850;
    justify-content: center;
    line-height: 1.1;
    min-height: 42px;
    padding: 10px 14px;
    text-decoration: none;
    width: 100%;
  }

  :global(.connect-button:hover) {
    background: var(--color-lbs-red);
