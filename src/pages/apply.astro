---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/atoms/Button.astro";
---

<BaseLayout
  title="Apply"
  description="Register interest for the September 2026 LBS AI Lab cohort and learn to build AI products with real LBS users."
>
  <section class="page-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Apply</p>
        <h1>Build with AI. Learn from real users.</h1>
        <p class="lede">
          The September 2026 cohort is for LBS students who want to prototype
          fast, test with students and alumni, and improve from feedback.
        </p>
        <Button
          href="#register-interest"
          variant="red"
          size="lg"
          external={false}
        >
          Register interest for September 2026
        </Button>
      </div>
      <aside>
        <span>Cohort 02</span>
        <strong>September 2026</strong>
        <ul>
          <li>Build with AI-assisted tools</li>
          <li>Test with real LBS users</li>
          <li>Iterate with mentor support</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section section-warm" id="register-interest">
    <div class="container form-grid">
      <div>
        <p class="eyebrow">Register interest</p>
        <h2>Tell us who you are.</h2>
        <p>
          Share your LBS details for the September 2026 cohort list. The Lab
          team will follow up when applications open and sessions are announced.
        </p>
      </div>

      <form class="interest-form" data-application-form>
        <label>
          <span>Name</span>
          <input name="name" autocomplete="name" required />
        </label>
        <label>
          <span>LBS email</span>
          <input
            name="lbs_email"
            type="email"
            autocomplete="email"
            pattern={"^[^@\\s]+@london\\.edu$"}
            placeholder="name.program@london.edu"
            required
          />
        </label>
        <label>
          <span>Course name</span>
          <input
            name="course_name"
            autocomplete="organization-title"
            placeholder="MBA, MiF, MAM..."
            required
          />
        </label>
        <label>
          <span>What would you like to build?</span>
          <textarea name="build_interest" rows="4" maxlength="900" required
          ></textarea>
        </label>
        <label class="consent-field">
          <input name="public_consent" type="checkbox" value="yes" required />
          <span>
            Show my name, course, and idea on this page so other LBS builders
            can contact me about working together.
          </span>
        </label>
        <label class="bot-field" aria-hidden="true">
          <span>Website</span>
          <input name="website" tabindex="-1" autocomplete="off" />
        </label>
        <p class="form-status" data-form-status role="status"></p>
        <button type="submit">Submit interest</button>
      </form>
    </div>
  </section>

  <section class="section submissions-section" id="submissions">
    <div class="container submissions-grid">
      <div>
        <p class="eyebrow">Find co-builders</p>
        <h2>See who is looking for people to build with.</h2>
        <p>
          Students who opt in can share their name, course, and build idea here.
          Use the contact button to start a conversation about working together.
        </p>
      </div>

      <div class="submissions-panel">
        <div class="submissions-top">
          <strong>September 2026 submissions</strong>
        </div>
        <p class="submissions-status" data-submissions-status role="status" hidden></p>
        <div class="submission-list" data-submission-list hidden></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container apply-grid">
      <section>
        <p class="eyebrow">Who this is for</p>
        <h2>Students who want to learn how to build something people want.</h2>
        <ul>
          <li>LBS students with a product idea.</li>
          <li>Operators who see a workflow that can be made better with AI.</li>
          <li>Future founders looking for co-builders and early users.</li>
          <li>
            Students who want practical AI fluency beyond classroom learning.
          </li>
        </ul>
      </section>

      <section>
        <p class="eyebrow">What you will do</p>
        <h2>Move from problem to prototype to user feedback.</h2>
        <ul>
          <li>Form or join a team.</li>
          <li>Choose a real LBS use case.</li>
          <li>Prototype with AI-assisted tools.</li>
          <li>Test with LBS students and alumni.</li>
          <li>Improve based on feedback.</li>
          <li>Work with mentors.</li>
          <li>Demo what you build.</li>
        </ul>
      </section>

      <section>
        <p class="eyebrow">What you do not need</p>
        <h2>You do not need to be a professional software engineer.</h2>
        <p>
          You do need curiosity, discipline, and willingness to learn by
          shipping. The Lab is practical, team-based, and focused on the real
          product loop.
        </p>
      </section>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const form = document.querySelector("[data-application-form]");
  const formStatus = document.querySelector("[data-form-status]");
  const submissionsStatus = document.querySelector("[data-submissions-status]");
  const submissionsList = document.querySelector("[data-submission-list]");

  const setText = (node, text) => {
    if (node) {
      node.textContent = text;
    }
  };

  const setStatus = (text, hidden = false) => {
    if (submissionsStatus) {
      submissionsStatus.textContent = text;
      submissionsStatus.hidden = hidden;
    }
  };

  const contactHref = (application) => {
    const subject = `LBS AI Lab: exploring your ${application.course} build idea`;
    const body = `Hi ${application.name.split(" ")[0]},\n\nI saw your LBS AI Lab submission. Would you be open to chatting about working together?\n\n`;
    return `mailto:${application.email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  };

  const tableCell = (label, text) => {
    const cell = document.createElement("td");
    cell.dataset.label = label;
    cell.textContent = text;
    return cell;
  };

  const ideaText = (idea) =>
    String(idea || "")
      .replace(/\s+/g, " ")
      .trim();

  const renderSubmissions = (applications) => {
    if (!submissionsList) return;

    submissionsList.innerHTML = "";

    if (!applications.length) {
      submissionsList.hidden = true;
      setStatus(
        "No public submissions yet. Be the first to share a build idea.",
      );
      return;
    }

    const wrapper = document.createElement("div");
    wrapper.className = "submissions-table-scroll";

    const table = document.createElement("table");
    table.className = "submissions-table";

    const thead = document.createElement("thead");
    const headerRow = document.createElement("tr");

    for (const label of ["Name", "Course", "Idea", ""]) {
      const header = document.createElement("th");
      header.scope = "col";
      if (!label) {
        header.setAttribute("aria-label", "Connect");
      }
      header.textContent = label;
      headerRow.append(header);
    }

    thead.append(headerRow);

    const tbody = document.createElement("tbody");

    for (const application of applications) {
      const row = document.createElement("tr");

      const name = tableCell("Name", application.name);
      name.className = "submission-name";

      const course = tableCell("Course", application.course);
      course.className = "submission-course";

      const idea = tableCell("Idea", ideaText(application.idea));
      idea.className = "submission-idea";

      const action = document.createElement("td");
      action.className = "submission-action";

      const contact = document.createElement("a");
      contact.href = contactHref(application);
      contact.className = "connect-button";
      contact.textContent = "Connect";

      action.append(contact);
      row.append(name, course, idea, action);
      tbody.append(row);
    }

    table.append(thead, tbody);
    wrapper.append(table);
    submissionsList.append(wrapper);

    submissionsList.hidden = false;
    setStatus(
      `${applications.length} public submission${applications.length === 1 ? "" : "s"} found.`,
    );
  };

  const loadSubmissions = async () => {
    if (!submissionsList) return;

    setStatus("", true);

    try {
      const response = await fetch("/api/applications", {
        headers: { Accept: "application/json" },
      });
      const data = response.headers
        .get("Content-Type")
        ?.includes("application/json")
        ? await response.json()
        : {};

      if (!response.ok) {
        throw new Error(data.error || "Submissions are not available yet.");
      }

      if (data.error) {
        throw new Error("Submissions are not available yet.");
      }

      renderSubmissions(data.applications || []);
    } catch (error) {
      submissionsList.hidden = true;
      setStatus(
        error instanceof Error
          ? error.message
          : "Submissions are not available yet.",
      );
    }
  };

  loadSubmissions();

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const submitButton = form.querySelector('button[type="submit"]');
    const payload = Object.fromEntries(new FormData(form).entries());

    setText(formStatus, "Submitting...");
    submitButton?.setAttribute("disabled", "true");

    try {
      const response = await fetch("/api/applications", {
        method: "POST",
        headers: {
          Accept: "application/json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });
      const data = response.headers
        .get("Content-Type")
        ?.includes("application/json")
        ? await response.json()
        : {};

      if (!response.ok) {
        throw new Error(data.error || "Submission failed.");
      }

      form.reset();
      setText(
        formStatus,
        "Submitted. Your idea will appear below once the public log updates.",
      );
      await loadSubmissions();
    } catch (error) {
      setText(
        formStatus,
        error instanceof Error
          ? error.message
          : "Submission failed. Please try again.",
      );
    } finally {
      submitButton?.removeAttribute("disabled");
    }
  });
</script>

<style>
  .page-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(52px, 7vw, 92px);
  }

  .hero-grid {
    align-items: center;
    display: grid;
    gap: clamp(34px, 6vw, 80px);
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
  }

  .hero-grid > * {
    min-width: 0;
  }

  :global(.page-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  h1 {
    color: var(--color-white);
    margin: 20px 0;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    margin-bottom: 30px;
    max-width: 820px;
  }

  aside {
    border: 1px solid rgba(255, 255, 255, 0.22);
    padding: 28px;
  }

  aside span {
    color: rgba(255, 255, 255, 0.65);
    font-weight: 820;
  }

  aside strong {
    display: block;
    font-family: var(--font-serif);
    font-size: var(--step-2);
    line-height: 1;
    margin: 14px 0;
  }

  aside ul {
    display: grid;
    gap: 10px;
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
  }

  aside li {
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.72);
    font-weight: 760;
    padding-top: 10px;
  }

  .apply-grid {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .apply-grid section {
    border: 1px solid var(--color-border);
    display: grid;
    gap: 14px;
    grid-template-rows: auto minmax(5.8rem, auto) 1fr;
    padding: clamp(24px, 4vw, 34px);
  }

  .apply-grid h2 {
    color: var(--color-lbs-blue);
    font-size: var(--step-2);
    margin: 16px 0;
  }

  .apply-grid p:not(.eyebrow),
  li {
    color: var(--color-ink-soft);
  }

  .apply-grid ul {
    display: grid;
    gap: 10px;
    margin: 0;
    padding-left: 19px;
  }

  .form-grid {
    align-items: start;
    display: grid;
    gap: clamp(28px, 5vw, 70px);
    grid-template-columns: minmax(0, 0.58fr) minmax(320px, 0.72fr);
  }

  .form-grid h2 {
    color: var(--color-lbs-blue);
    margin: 16px 0;
  }

  .form-grid p:not(.eyebrow) {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
  }

  .interest-form {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: grid;
    gap: 18px;
    padding: clamp(22px, 4vw, 36px);
  }

  label {
    display: grid;
    gap: 8px;
  }

  label span {
    color: var(--color-lbs-blue);
    font-size: var(--step--1);
    font-weight: 820;
  }

  .consent-field {
    align-items: start;
    display: grid;
    gap: 12px;
    grid-template-columns: 20px 1fr;
  }

  .consent-field input {
    margin-top: 3px;
    min-height: 20px;
    padding: 0;
    width: 20px;
  }

  .consent-field span {
    color: var(--color-ink-soft);
    font-size: 0.9rem;
    font-weight: 760;
    line-height: 1.45;
  }

  .bot-field {
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    height: 1px;
    overflow: hidden;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  input,
  textarea {
    background: var(--color-white);
    border: 1px solid var(--color-border-strong);
    border-radius: 0;
    color: var(--color-ink);
    min-height: 48px;
    padding: 12px 14px;
    width: 100%;
  }

  textarea {
    min-height: 120px;
    resize: vertical;
  }

  button {
    background: var(--color-lbs-red);
    border: 0;
    border-radius: var(--radius-button);
    color: var(--color-white);
    cursor: pointer;
    font-weight: 850;
    min-height: 52px;
    padding: 14px 22px;
  }

  button:disabled {
    cursor: wait;
    opacity: 0.66;
  }

  .form-status {
    color: var(--color-ink-soft);
    font-size: var(--step--1);
    font-weight: 760;
    min-height: 1.4em;
  }

  .submissions-section {
    background: var(--color-white);
  }

  .submissions-grid {
    align-items: start;
    display: grid;
    gap: clamp(24px, 4vw, 42px);
    grid-template-columns: 1fr;
  }

  .submissions-grid h2 {
    color: var(--color-lbs-blue);
    margin: 16px 0;
  }

  .submissions-grid > div:first-child {
    max-width: 820px;
  }

  .submissions-grid p:not(.eyebrow) {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
  }

  .submissions-panel {
    background: var(--color-warm-white);
    border: 1px solid var(--color-border);
    display: grid;
    gap: 18px;
    padding: clamp(20px, 3vw, 30px);
  }

  .submissions-top {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: space-between;
  }

  .submissions-top strong {
    color: var(--color-lbs-blue);
    font-size: var(--step-1);
  }

  .submissions-status {
    color: var(--color-muted);
    font-size: var(--step--1) !important;
    font-weight: 760;
  }

  .submission-list {
    overflow: hidden;
  }

  :global(.submissions-table-scroll) {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    overflow-x: auto;
  }

  :global(.submissions-table) {
    border-collapse: collapse;
    color: var(--color-ink);
    min-width: 720px;
    table-layout: fixed;
    width: 100%;
  }

  :global(.submissions-table th),
  :global(.submissions-table td) {
    border-bottom: 1px solid var(--color-border);
    padding: 16px 18px;
    text-align: left;
    vertical-align: top;
  }

  :global(.submissions-table th) {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    font-size: var(--step--1);
    font-weight: 820;
    letter-spacing: 0;
  }

  :global(.submissions-table td) {
    color: var(--color-ink-soft);
    font-size: 0.98rem;
    line-height: 1.42;
  }

  :global(.submissions-table tbody tr:last-child td) {
    border-bottom: 0;
  }

  :global(.submissions-table th:nth-child(1)),
  :global(.submissions-table td:nth-child(1)) {
    width: 22%;
  }

  :global(.submissions-table th:nth-child(2)),
  :global(.submissions-table td:nth-child(2)) {
    width: 15%;
  }

  :global(.submissions-table th:nth-child(4)),
  :global(.submissions-table td:nth-child(4)) {
    width: 24%;
  }

  :global(.submission-name) {
    color: var(--color-lbs-blue) !important;
    font-weight: 850;
  }

  :global(.submission-course) {
    color: var(--color-lbs-red) !important;
    font-weight: 820;
  }

  :global(.submission-idea) {
    overflow-wrap: anywhere;
  }

  :global(.connect-button) {
    align-items: center;
    background: var(--color-lbs-blue);
    border-radius: var(--radius-button);
    color: var(--color-white);
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 850;
    justify-content: center;
    line-height: 1.1;
    min-height: 42px;
    padding: 10px 14px;
    text-decoration: none;
    width: 100%;
  }

  :global(.connect-button:hover) {
    background: var(--color-lbs-red);
  }

  @media (max-width: 940px) {
    .hero-grid,
    .apply-grid,
    .form-grid,
    .submissions-grid {
      grid-template-columns: 1fr;
    }

    .apply-grid section {
      grid-template-rows: auto;
    }
  }

  @media (max-width: 520px) {
    .page-hero {
      padding-block: 42px 48px;
    }

    aside {
      padding: 20px;
    }

    :global(.submissions-table-scroll) {
      border: 0;
      overflow: visible;
    }

    :global(.submissions-table) {
      min-width: 0;
    }

    :global(.submissions-table thead) {
      display: none;
    }

    :global(.submissions-table),
    :global(.submissions-table tbody),
    :global(.submissions-table tr),
    :global(.submissions-table td) {
      display: block;
      width: 100%;
    }

    :global(.submissions-table tr) {
      background: var(--color-white);
      border: 1px solid var(--color-border);
      margin-bottom: 12px;
      padding: 14px;
    }

    :global(.submissions-table tr:last-child) {
      margin-bottom: 0;
    }

    :global(.submissions-table td) {
      border: 0;
      display: grid;
      gap: 6px;
      padding: 8px 0;
    }

    :global(.submissions-table td:nth-child(n)) {
      width: 100%;
    }

    :global(.submissions-table td::before) {
      color: var(--color-muted);
      content: attr(data-label);
      font-size: 0.76rem;
      font-weight: 820;
      text-transform: uppercase;
    }

    :global(.submission-action::before) {
      content: none;
    }

    :global(.connect-button) {
      margin-top: 4px;
      width: 100%;
    }
  }
</style>
