---
const title = "Page not found | LBS AI Lab";
const description =
  "This LBS AI Lab page could not be found. Use the sitemap or return home to find public Lab pages";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="theme-color" content="#17145f" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" type="image/x-icon" />
    <link rel="icon" href="/favicon/favicon.ico" type="image/x-icon" />
  </head>
  <body>
    <main>
      <a class="brand" href="/" aria-label="LBS AI Lab home">
        <img src="/lbs-logo.svg" alt="" width="44" height="44" />
        <span>LBS AI Lab</span>
      </a>
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p class="lede">
        This page may have moved, changed name, or been removed from the public
        site
      </p>
      <nav aria-label="Not found page links">
        <a class="primary" href="/">Go home</a>
        <a href="/sitemap/">View sitemap</a>
      </nav>
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    background: #fbfaf7;
    color: #17145f;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
  }

  main {
    display: grid;
    gap: 22px;
    margin-inline: auto;
    max-width: 760px;
    min-height: 100vh;
    padding: clamp(32px, 7vw, 76px) 24px;
    place-content: center start;
  }

  .brand {
    align-items: center;
    color: #17145f;
    display: inline-flex;
    font-weight: 860;
    gap: 12px;
    text-decoration: none;
  }

  .brand img {
    background: #17145f;
    display: block;
  }

  .eyebrow {
    align-items: center;
    color: #17145f;
    display: inline-flex;
    font-size: 0.96rem;
    font-weight: 860;
    gap: 10px;
    margin: 18px 0 0;
  }

  .eyebrow::before {
    background: #f1111f;
    content: "";
    display: inline-block;
    height: 2px;
    width: 36px;
  }

  h1 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3rem, 9vw, 6rem);
    line-height: 0.92;
    margin: 0;
  }

  .lede {
    color: #343a78;
    font-size: clamp(1.1rem, 2.4vw, 1.45rem);
    line-height: 1.45;
    margin: 0;
    max-width: 620px;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 8px;
  }

  a {
    border: 1px solid #c9ccdc;
    border-radius: 999px;
    color: #17145f;
    font-weight: 860;
    padding: 13px 19px;
    text-decoration: none;
  }

  a:hover {
    border-color: #17145f;
  }

  .primary {
    background: #17145f;
    border-color: #17145f;
    color: #ffffff;
  }

  @media (max-width: 520px) {
    nav,
    nav a {
      width: 100%;
    }

    nav a {
      text-align: center;
    }
  }
</style>
