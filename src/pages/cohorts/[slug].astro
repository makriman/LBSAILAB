---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import CohortDetail from "@components/sections/CohortDetail.astro";
import { sortTeamsByCohortList } from "@utils/collections";

export async function getStaticPaths() {
  const cohorts = await getCollection("cohorts");
  return cohorts.map((cohort) => ({
    params: { slug: cohort.data.slug },
    props: { cohort },
  }));
}

const { cohort } = Astro.props;
const [allTeams, mentors] = await Promise.all([
  getCollection("teams"),
  getCollection("mentors"),
]);
const teams = sortTeamsByCohortList(
  allTeams.filter((team) => team.data.cohort === cohort.data.id),
  cohort.data.teams,
);
const description =
  cohort.data.id === "cohort-01"
    ? "Meet Cohort 01 of LBS AI Lab, delivered in partnership with Google DeepMind, with nine student teams building AI products from 10 April to 12 June 2026."
    : "The next LBS AI Lab cohort starts in September 2026 for students who want to build AI products and test with real users.";
---

<BaseLayout
  title={`${cohort.data.name} | LBS AI Lab`}
  description={description}
>
  <CohortDetail cohort={cohort} teams={teams} mentors={mentors} />
</BaseLayout>
