---
import BaseLayout from "@layouts/BaseLayout.astro";
import SectionHeader from "@components/atoms/SectionHeader.astro";
import DSAIBlock from "@components/sections/DSAIBlock.astro";
---

<BaseLayout
  title="About LBS AI Lab"
  description="LBS AI Lab teaches London Business School students to build AI products, test with real users, and iterate from feedback."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">About LBS AI Lab</p>
      <h1>The Lab teaches the full build loop.</h1>
      <p class="lede">
        Students learn how to build quickly with AI-assisted tools, put products
        in front of real LBS users, and improve based on what those users
        actually do and say.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container editorial-grid">
      <article>
        <p class="eyebrow">Why now</p>
        <h2>Building has become easier. Learning from users has not.</h2>
        <p>
          Agentic engineering, AI-assisted coding, and modern automation tools
          have made it dramatically easier to create software. The new
          bottleneck is not only technical execution. It is getting real users,
          learning from their feedback, and improving the product until it
          solves a problem that matters.
        </p>
      </article>

      <article>
        <p class="eyebrow">What makes the Lab different</p>
        <h2>The audience is built into the model.</h2>
        <ul>
          <li>Every project is built for an LBS use case.</li>
          <li>
            Teams can test with the 2,000-student LBS community and alumni
            network.
          </li>
          <li>Students learn the new build stack through hands-on sessions.</li>
          <li>
            Mentors and partners help teams sharpen product and technical
            decisions.
          </li>
          <li>
            The goal is not a demo alone. It is learning how to build something
            people want.
          </li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section section-warm">
    <div class="container">
      <SectionHeader
        eyebrow="How the Lab works"
        title="A cohort-based build environment with a real feedback loop."
        body="Students form or join teams, choose LBS problems, build prototypes with modern AI tools, test with real users, and iterate with mentor support."
      />
      <div class="process-grid">
        <article>
          <span>01</span>
          <h3>Choose an LBS use case</h3>
          <p>
            Teams start from practical student, alumni, operator, or campus
            workflows.
          </p>
        </article>
        <article>
          <span>02</span>
          <h3>Build with AI tools</h3>
          <p>
            Sessions teach students how to use agentic engineering to move from
            thesis to working product.
          </p>
        </article>
        <article>
          <span>03</span>
          <h3>Test with real users</h3>
          <p>
            Teams put prototypes in front of LBS students and alumni to learn
            from real behaviour.
          </p>
        </article>
        <article>
          <span>04</span>
          <h3>Iterate and demo</h3>
          <p>
            Cohorts culminate in a showcase after teams have improved through
            feedback.
          </p>
        </article>
      </div>
    </div>
  </section>

  <DSAIBlock />
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(52px, 7vw, 92px);
  }

  :global(.page-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  h1 {
    color: var(--color-white);
    margin: 20px 0;
    max-width: 900px;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    max-width: 780px;
  }

  .editorial-grid {
    display: grid;
    gap: clamp(36px, 6vw, 86px);
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.92fr);
  }

  article {
    border-top: 3px solid var(--color-lbs-red);
    padding-top: 24px;
  }

  article h2 {
    color: var(--color-lbs-blue);
    font-size: var(--step-2);
    margin: 16px 0;
  }

  article p,
  li {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
  }

  ul {
    display: grid;
    gap: 12px;
    margin: 0;
    padding-left: 20px;
  }

  .process-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 34px;
  }

  .process-grid article {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: grid;
    gap: 12px;
    grid-template-rows: auto minmax(3.1rem, auto) 1fr;
    padding: clamp(24px, 4vw, 34px);
  }

  .process-grid span {
    color: var(--color-lbs-red);
    font-weight: 900;
  }

  @media (max-width: 860px) {
    .editorial-grid,
    .process-grid {
      grid-template-columns: 1fr;
    }

    .process-grid article {
      grid-template-rows: auto;
    }
  }
</style>
