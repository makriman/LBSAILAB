---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/atoms/Button.astro";
import ApplyCTA from "@components/sections/ApplyCTA.astro";
---

<BaseLayout
  title="About LBS AI Lab"
  description="LBS AI Lab helps participants get involved in AI solution development at London Business School"
>
  <section class="page-hero">
    <div class="container hero-inner">
      <p class="eyebrow">About LBS AI Lab</p>
      <h1>A hands-on AI lab for the LBS community</h1>
      <p class="lede">
        LBS AI Lab helps participants get involved in AI solution development at
        the School, from identifying opportunities to prototyping and deploying
        useful products for the LBS community
      </p>
      <div class="hero-actions">
        <Button href="/apply/" variant="red" size="lg">
          Join the next batch
        </Button>
        <Button href="/batches/spring-2026/" variant="ghost" size="lg">
          View Spring 2026 Batch
        </Button>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container text-grid">
      <p class="eyebrow">Why the Lab exists</p>
      <div>
        <h2>Why the Lab exists</h2>
        <p>
          AI is changing how organisations identify problems, build solutions,
          and create value. LBS AI Lab was created to give the student community
          a direct way to explore that shift through hands-on product
          development
        </p>
        <p>
          The Lab connects participants with LBS workflows, stakeholders, and
          mentors so they can develop AI solutions that respond to needs across
          the School
        </p>
      </div>
    </div>
  </section>

  <section class="section section-warm">
    <div class="container text-grid">
      <p class="eyebrow">For participants</p>
      <div>
        <h2>For participants</h2>
        <p>
          The Lab gives participants practical experience with AI-based
          application development, from ideation to prototyping and deployment.
          Along the way, they learn how to define problems, speak with users,
          manage stakeholders, evaluate outputs, and iterate toward products
          that can be adopted
        </p>
        <p>
          It is also a way for participants to contribute directly to the School
          and develop the technical and product fluency needed for their future
          careers
        </p>
      </div>
    </div>
  </section>

  <section class="section batch-model">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">An 8-week batch model</p>
        <h2>An 8-week batch model</h2>
        <p>
          Each batch brings together teams for an 8-week cycle of discovery,
          product development, evaluation, and iteration
        </p>
      </div>
      <div class="model-grid">
        <article>
          <h3>Discover</h3>
          <p>
            Identify an LBS workflow, define the problem, and understand the
            user
          </p>
        </article>
        <article>
          <h3>Build</h3>
          <p>
            Prototype with AI-assisted tools and make product decisions quickly
          </p>
        </article>
        <article>
          <h3>Evaluate</h3>
          <p>Test quality, gather feedback, and improve through iteration</p>
        </article>
      </div>
    </div>
  </section>

  <ApplyCTA />
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(56px, 7vw, 96px);
  }

  .hero-inner {
    max-width: 980px;
  }

  :global(.page-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  h1 {
    color: var(--color-white);
    margin: 20px 0;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    max-width: 820px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .text-grid {
    display: grid;
    gap: clamp(24px, 6vw, 76px);
    grid-template-columns: minmax(180px, 0.28fr) minmax(0, 1fr);
  }

  .text-grid h2,
  .section-intro h2 {
    color: var(--color-lbs-blue);
    margin: 0 0 18px;
  }

  .text-grid p:not(.eyebrow),
  .section-intro p:not(.eyebrow) {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
    max-width: 900px;
  }

  .text-grid p + p {
    margin-top: 18px;
  }

  .section-intro {
    max-width: 820px;
  }

  .model-grid {
    display: grid;
    gap: 0;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 36px;
  }

  .model-grid article {
    border-left: 1px solid var(--color-border);
    border-top: 2px solid var(--color-lbs-red);
    padding: 22px;
  }

  .model-grid article:first-child {
    border-left: 0;
    padding-left: 0;
  }

  .model-grid h3 {
    color: var(--color-lbs-blue);
    font-family: var(--font-sans);
    font-size: var(--step-1);
    margin: 0 0 12px;
  }

  .model-grid p {
    color: var(--color-ink-soft);
    margin: 0;
  }

  @media (max-width: 760px) {
    .text-grid,
    .model-grid {
      grid-template-columns: 1fr;
    }

    .model-grid article,
    .model-grid article:first-child {
      border-left: 0;
      padding-inline: 0;
    }
  }
</style>
