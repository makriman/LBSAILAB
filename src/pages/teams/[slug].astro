---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import TeamDetail from '@components/sections/TeamDetail.astro';
import { sortTeamsByCohortList } from '@utils/collections';

export async function getStaticPaths() {
  const teams = await getCollection('teams');
  return teams.map((team) => ({
    params: { slug: team.data.slug },
    props: { team },
  }));
}

const { team } = Astro.props;
const [allTeams, cohorts] = await Promise.all([getCollection('teams'), getCollection('cohorts')]);
const cohort = cohorts.find((entry) => entry.data.id === team.data.cohort);
const cohortTeams = cohort ? sortTeamsByCohortList(allTeams, cohort.data.teams) : allTeams;
const relatedTeams = cohortTeams
  .filter((entry) => entry.data.slug !== team.data.slug)
  .slice(0, 3);
---

<BaseLayout
  title={`${team.data.displayName} | LBS AI Lab Cohort 01`}
  description={team.data.tagline}
>
  <TeamDetail team={team} relatedTeams={relatedTeams} />
</BaseLayout>
