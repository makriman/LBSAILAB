---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import TeamGrid from "@components/sections/TeamGrid.astro";
import { sortTeamsByCohortList } from "@utils/collections";
import { SITE_URL } from "@utils/site";

const [teams, cohorts] = await Promise.all([
  getCollection("teams"),
  getCollection("cohorts"),
]);
const cohort01 = cohorts.find((cohort) => cohort.data.id === "cohort-01");
const sortedTeams = cohort01
  ? sortTeamsByCohortList(teams, cohort01.data.teams)
  : teams;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "LBS AI Lab teams",
  itemListElement: sortedTeams.map((team, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: `${SITE_URL}/teams/${team.data.slug}/`,
    name: team.data.displayName,
  })),
};
---

<BaseLayout
  title="Teams"
  description="Explore AI products created by LBS AI Lab student teams for real LBS use cases, from internal tools to venture-scale prototypes."
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Teams</p>
      <h1>Products built for real LBS use cases.</h1>
      <p class="lede">
        Explore AI products created by students across cohorts, from internal
        LBS tools to venture-scale prototypes with real audiences to learn from.
      </p>
    </div>
  </section>

  <section class="section section-warm">
    <div class="container">
      <div class="directory-bar">
        <div>
          <strong>Cohort</strong>
          <a href="#teams">Cohort 01 / Google DeepMind partner cohort</a>
        </div>
      </div>
      <div id="teams">
        <TeamGrid teams={sortedTeams} />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(74px, 11vw, 132px);
  }

  :global(.page-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  h1 {
    color: var(--color-white);
    margin: 20px 0;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    max-width: 820px;
  }

  .directory-bar {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
    margin-bottom: 28px;
    padding: 20px;
  }

  .directory-bar strong {
    color: var(--color-lbs-blue);
    display: block;
    font-size: var(--step--1);
    margin-bottom: 8px;
  }

  .directory-bar a {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    color: var(--color-lbs-blue);
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 800;
    margin: 0 6px 8px 0;
    padding: 8px 11px;
    text-decoration: none;
  }

  @media (max-width: 760px) {
    .directory-bar {
      grid-template-columns: 1fr;
    }
  }
</style>
