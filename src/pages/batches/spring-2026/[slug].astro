---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import TeamDetail from "@components/sections/TeamDetail.astro";
import { DEFAULT_OG_IMAGE, pageJsonLd, teamProfileJsonLd } from "@utils/seo";

export async function getStaticPaths() {
  const teams = await getCollection("teams");
  return teams
    .filter((team) => team.data.batch === "spring-2026")
    .map((team) => ({
      params: { slug: team.data.slug },
      props: { team },
    }));
}

const { team } = Astro.props;
const pageTitle =
  team.data.seoTitle ?? `${team.data.displayName} | Spring 2026 Batch`;
const pageDescription = team.data.seoDescription ?? team.data.tagline;
const pagePath = `/batches/spring-2026/${team.data.slug}/`;
const pageImage = team.data.seoImage ?? DEFAULT_OG_IMAGE;
const pageImageAlt =
  team.data.seoImageAlt ??
  `${team.data.displayName} profile in the LBS AI Lab Spring 2026 Batch`;
const jsonLd = [
  ...pageJsonLd({
    title: pageTitle,
    description: pageDescription,
    path: pagePath,
    image: pageImage,
    updatedAt: team.data.updatedAt,
    breadcrumbs: [
      { name: "LBS AI Lab", path: "/" },
      { name: "Batches", path: "/batches/" },
      { name: "Spring 2026 Batch", path: "/batches/spring-2026/" },
      { name: team.data.displayName, path: pagePath },
    ],
  }),
  ...teamProfileJsonLd({
    name: team.data.displayName,
    description: team.data.summary,
    path: pagePath,
    category: team.data.category,
    productUrl: team.data.productUrl,
    members: team.data.members.map((member) => ({
      name: member.name,
      role: member.role,
    })),
  }),
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={pageImage}
  imageAlt={pageImageAlt}
  jsonLd={jsonLd}
>
  <TeamDetail team={team} />
</BaseLayout>
