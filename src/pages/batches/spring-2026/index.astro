---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/atoms/Button.astro";
import TeamGrid from "@components/sections/TeamGrid.astro";
import ApplyCTA from "@components/sections/ApplyCTA.astro";
import { sortTeamsByBatchList } from "@utils/collections";

const [teams, batches] = await Promise.all([
  getCollection("teams"),
  getCollection("batches"),
]);

const springBatch = batches.find((batch) => batch.data.id === "spring-2026");
const springTeams = springBatch
  ? sortTeamsByBatchList(
      teams.filter((team) => team.data.batch === springBatch.data.id),
      springBatch.data.teams,
    )
  : teams;
---

<BaseLayout
  title="Spring 2026 Batch"
  description="Meet the Spring 2026 Batch of LBS AI Lab teams building AI products for LBS workflows"
>
  <section class="page-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Spring 2026 Batch</p>
        <h1>Nine teams building AI products for LBS workflows</h1>
        <p class="lede">
          Nine teams joined the first LBS AI Lab batch to build AI products for
          LBS workflows
        </p>
        <div class="hero-actions">
          <Button href="/apply/" variant="red" size="lg">
            Join the next batch
          </Button>
          <Button href="#teams" variant="ghost" size="lg" external={false}>
            View teams
          </Button>
        </div>
      </div>
      <aside class="stats-panel" aria-label="Spring 2026 Batch facts">
        <div><strong>9</strong><span>teams</span></div>
        <div><strong>22</strong><span>builders</span></div>
        <div><strong>4</strong><span>mentors</span></div>
        <div><strong>8</strong><span>weeks</span></div>
      </aside>
    </div>
  </section>

  <section class="section section-warm" id="teams">
    <div class="container section-intro">
      <p class="eyebrow">Teams</p>
      <h2>Spring 2026 teams</h2>
      <p>
        Teams are grouped here as a compact directory. Each profile includes the
        product overview, team members, and prototype link where available
      </p>
    </div>
    <div class="container team-list">
      <TeamGrid teams={springTeams} />
    </div>
  </section>

  <ApplyCTA />
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(52px, 7vw, 92px);
  }

  .hero-grid {
    align-items: end;
    display: grid;
    gap: clamp(30px, 6vw, 72px);
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.44fr);
  }

  :global(.page-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  h1 {
    color: var(--color-white);
    margin: 20px 0;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    max-width: 820px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .stats-panel {
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .stats-panel div {
    border-left: 1px solid rgba(255, 255, 255, 0.16);
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    display: grid;
    gap: 6px;
    padding: 18px;
  }

  .stats-panel div:nth-child(odd) {
    border-left: 0;
  }

  .stats-panel div:nth-child(-n + 2) {
    border-top: 0;
  }

  .stats-panel strong {
    color: var(--color-white);
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 0.95;
  }

  .stats-panel span {
    color: rgba(255, 255, 255, 0.72);
    font-size: var(--step--1);
    font-weight: 820;
  }

  .section-intro h2 {
    color: var(--color-lbs-blue);
    margin: 12px 0;
  }

  .section-intro p:not(.eyebrow) {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
    max-width: 780px;
  }

  .team-list {
    margin-top: 34px;
  }

  @media (max-width: 820px) {
    .hero-grid,
    .stats-panel {
      grid-template-columns: 1fr;
    }

    .stats-panel div,
    .stats-panel div:nth-child(odd),
    .stats-panel div:nth-child(-n + 2) {
      border-left: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.16);
    }

    .stats-panel div:first-child {
      border-top: 0;
    }
  }
</style>
