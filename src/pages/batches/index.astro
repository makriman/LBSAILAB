---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/atoms/Button.astro";
import GoogleDeepMindLogo from "@components/brand/GoogleDeepMindLogo.astro";
import TeamGrid from "@components/sections/TeamGrid.astro";
import ApplyCTA from "@components/sections/ApplyCTA.astro";
import { sortTeamsByBatchList } from "@utils/collections";
import {
  itemListJsonLd,
  pageJsonLd,
  SPRING_BATCH_OG_IMAGE,
  SPRING_BATCH_OG_IMAGE_ALT,
  springBatchPartnerJsonLd,
} from "@utils/seo";

const [teams, batches] = await Promise.all([
  getCollection("teams"),
  getCollection("batches"),
]);

const springBatch = batches.find((batch) => batch.data.id === "spring-2026");
const springTeams = springBatch
  ? sortTeamsByBatchList(
      teams.filter((team) => team.data.batch === springBatch.data.id),
      springBatch.data.teams,
    )
  : teams;
const hasGoogleDeepMindPartner =
  springBatch?.data.partnerName === "Google DeepMind";

const pageTitle = "Batches";
const pageDescription =
  "Explore LBS AI Lab batches and teams building AI products for LBS workflows";
const jsonLd = [
  ...pageJsonLd({
    title: pageTitle,
    description: pageDescription,
    path: "/batches/",
    image: SPRING_BATCH_OG_IMAGE,
    breadcrumbs: [
      { name: "LBS AI Lab", path: "/" },
      { name: "Batches", path: "/batches/" },
    ],
  }),
  itemListJsonLd({
    name: "LBS AI Lab Spring 2026 Batch teams",
    description:
      "Spring 2026 Batch teams building AI products for LBS workflows",
    items: springTeams.map((team) => ({
      name: team.data.displayName,
      url: `/batches/spring-2026/${team.data.slug}/`,
      description: team.data.tagline,
    })),
  }),
];

if (hasGoogleDeepMindPartner) {
  jsonLd.push(springBatchPartnerJsonLd());
}
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={SPRING_BATCH_OG_IMAGE}
  imageAlt={SPRING_BATCH_OG_IMAGE_ALT}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container hero-inner">
      <p class="eyebrow">Batches</p>
      <h1>Teams building AI products for LBS workflows</h1>
      <p class="lede">
        Each LBS AI Lab batch brings together participants for an 8-week cycle
        of discovery, product development, evaluation, and iteration
      </p>
      <div class="hero-actions">
        <Button href="/apply/" variant="red" size="lg">
          Join the next batch
        </Button>
        <Button href="/batches/spring-2026/" variant="ghost" size="lg">
          View Spring 2026 Batch
        </Button>
      </div>
    </div>
  </section>

  <section class="section how-section">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">How batches work</p>
        <h2>How batches work</h2>
      </div>
      <div class="steps-grid">
        <article>
          <h3>Join</h3>
          <p>Participants form teams around an LBS workflow or opportunity</p>
        </article>
        <article>
          <h3>Build</h3>
          <p>Teams prototype with AI-assisted tools and product guidance</p>
        </article>
        <article>
          <h3>Share</h3>
          <p>
            Teams present what they built, what they learned, and where the
            product could go next
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-warm" id="spring-2026">
    <div class="container batch-top">
      <div>
        <p class="eyebrow">Spring 2026 Batch</p>
        <h2>Spring 2026 Batch</h2>
        <p>
          Nine teams joined the first LBS AI Lab batch to build AI products for
          LBS workflows
        </p>
        {
          hasGoogleDeepMindPartner && (
            <GoogleDeepMindLogo label="In partnership with" compact />
          )
        }
      </div>
      <Button href="/batches/spring-2026/" variant="secondary">
        View Spring 2026 Batch
      </Button>
    </div>
    <div class="container stats-row" aria-label="Spring 2026 Batch facts">
      <div><strong>9</strong><span>teams</span></div>
      <div><strong>22</strong><span>builders</span></div>
      <div><strong>4</strong><span>mentors</span></div>
      <div><strong>8</strong><span>weeks</span></div>
    </div>
    <div class="container team-list">
      <TeamGrid teams={springTeams} />
    </div>
  </section>

  <section class="section upcoming-section" id="autumn-2026">
    <div class="container upcoming-inner">
      <p class="eyebrow">Autumn 2026 Batch</p>
      <h2>Autumn 2026 Batch</h2>
      <p>The next batch opens in September 2026</p>
      <Button href="/apply/" variant="secondary">Join the next batch</Button>
    </div>
  </section>

  <ApplyCTA />
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(52px, 7vw, 92px);
  }

  .hero-inner {
    max-width: 940px;
  }

  :global(.page-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  h1 {
    color: var(--color-white);
    margin: 20px 0;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    max-width: 820px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .section-intro h2,
  .batch-top h2,
  .upcoming-inner h2 {
    color: var(--color-lbs-blue);
    margin: 12px 0;
  }

  .steps-grid {
    display: grid;
    gap: 0;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 28px;
  }

  .steps-grid article {
    border-top: 1px solid var(--color-border);
    padding: 22px 22px 0 0;
  }

  .steps-grid h3 {
    color: var(--color-lbs-blue);
    font-family: var(--font-sans);
    font-size: var(--step-1);
    margin: 0 0 10px;
  }

  .steps-grid p,
  .batch-top p,
  .upcoming-inner p {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
    margin: 0;
  }

  .batch-top :global(.gdm-lockup) {
    margin-top: 22px;
  }

  .batch-top {
    align-items: end;
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .stats-row {
    border-block: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 32px;
  }

  .stats-row div {
    border-left: 1px solid var(--color-border);
    display: grid;
    gap: 6px;
    padding: 15px 16px;
  }

  .stats-row div:first-child {
    border-left: 0;
  }

  .stats-row strong {
    color: var(--color-lbs-blue);
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 0.95;
  }

  .stats-row span {
    color: var(--color-muted);
    font-size: var(--step--1);
    font-weight: 820;
  }

  .team-list {
    margin-top: 34px;
  }

  .upcoming-section {
    border-top: 1px solid var(--color-border);
  }

  .upcoming-inner {
    max-width: 760px;
  }

  .upcoming-inner :global(.button) {
    margin-top: 24px;
  }

  @media (max-width: 820px) {
    .steps-grid,
    .batch-top,
    .stats-row {
      grid-template-columns: 1fr;
    }

    .batch-top :global(.button) {
      justify-self: start;
    }

    .stats-row div,
    .stats-row div:first-child {
      border-left: 0;
    }

    .stats-row div + div {
      border-top: 1px solid var(--color-border);
    }
  }
</style>
