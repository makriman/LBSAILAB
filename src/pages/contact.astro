---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/atoms/Button.astro";
import { DSAI_URL, MENTOR_APPLICATION_URL } from "@utils/site";
---

<BaseLayout
  title="Contact"
  description="Contact LBS AI Lab for questions about batches, mentoring, partnerships, user testing, or participant-built AI products"
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Contact LBS AI Lab</h1>
      <p class="lede">
        For questions about batches, mentoring, partnerships, user testing, or
        participant-built AI products, contact the LBS AI Lab team
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <article>
        <p class="eyebrow">General inquiries</p>
        <h2>Reach the Data Science & AI Initiative</h2>
        <p>
          For general questions, use the DSAI Initiative contact route while the
          dedicated AI Lab inbox is being set up.
        </p>
        <Button href={DSAI_URL} variant="secondary"
          >Visit the DSAI Initiative</Button
        >
      </article>

      <article>
        <p class="eyebrow">Team inquiries</p>
        <h2>Use team pages for product-specific introductions</h2>
        <p>
          Team pages list each builder and public email address for direct
          product questions, feedback, and testing interest.
        </p>
        <Button href="/batches/spring-2026/" variant="secondary">
          View Spring 2026 Batch
        </Button>
      </article>

      <article>
        <p class="eyebrow">Mentoring</p>
        <h2>Help teams sharpen product direction and execution</h2>
        <p>
          Alumni, operators, founders, and technical builders can register
          interest in supporting future batches as teams build, test, and
          iterate.
        </p>
        <Button href={MENTOR_APPLICATION_URL} variant="secondary">
          Apply to mentor
        </Button>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(52px, 7vw, 92px);
  }

  :global(.page-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  h1 {
    color: var(--color-white);
    margin: 20px 0;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    max-width: 760px;
  }

  .contact-grid {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  article {
    border: 1px solid var(--color-border);
    display: grid;
    gap: 18px;
    grid-template-rows: auto minmax(5.2rem, auto) 1fr auto;
    padding: clamp(24px, 4vw, 34px);
  }

  article h2 {
    color: var(--color-lbs-blue);
    font-size: var(--step-2);
    margin: 0;
  }

  article p:not(.eyebrow) {
    color: var(--color-ink-soft);
  }

  @media (max-width: 920px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    article {
      grid-template-rows: auto;
    }
  }
</style>
