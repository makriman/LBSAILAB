---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/atoms/Button.astro";
import { DSAI_URL } from "@utils/site";
---

<BaseLayout
  title="Contact"
  description="Contact LBS AI Lab for questions about cohorts, mentoring, partnerships, user testing, or student-built AI products."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Contact LBS AI Lab.</h1>
      <p class="lede">
        For questions about cohorts, mentoring, partnerships, user testing, or
        student-built AI products, contact the LBS AI Lab team.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <article>
        <p class="eyebrow">General inquiries</p>
        <h2>Use a confirmed Lab or DSAI contact before publishing.</h2>
        <p>
          A public lab email has not been confirmed in the project brief. This
          page is ready for the approved contact route once it is available.
        </p>
        <Button href={DSAI_URL} variant="secondary"
          >Visit the DSAI Initiative</Button
        >
      </article>

      <article>
        <p class="eyebrow">Team inquiries</p>
        <h2>Use team pages for product-specific introductions.</h2>
        <p>
          Team pages list each builder and public email address for direct
          product questions, feedback, and testing interest.
        </p>
        <Button href="/teams/" variant="secondary">View teams</Button>
      </article>

      <article>
        <p class="eyebrow">Mentoring</p>
        <h2>Help student teams sharpen product direction and execution.</h2>
        <p>
          Alumni, operators, founders, and technical builders can register
          interest in supporting future cohorts as teams build, test, and
          iterate.
        </p>
        <Button href="/apply/" variant="secondary">Register interest</Button>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(74px, 11vw, 132px);
  }

  :global(.page-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  h1 {
    color: var(--color-white);
    margin: 20px 0;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    max-width: 760px;
  }

  .contact-grid {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  article {
    border: 1px solid var(--color-border);
    display: grid;
    gap: 18px;
    padding: clamp(24px, 4vw, 34px);
  }

  article h2 {
    color: var(--color-lbs-blue);
    font-size: var(--step-2);
    margin: 0;
  }

  article p:not(.eyebrow) {
    color: var(--color-ink-soft);
  }

  @media (max-width: 920px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
