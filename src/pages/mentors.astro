---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/atoms/Button.astro";
import DirectorCard from "@components/cards/DirectorCard.astro";
import MentorGrid from "@components/sections/MentorGrid.astro";
import { MENTOR_APPLICATION_URL } from "@utils/site";
import { itemListJsonLd, pageJsonLd, personJsonLd } from "@utils/seo";

const mentors = await getCollection("mentors");
const pageTitle = "Mentors";
const pageDescription =
  "Meet the product and technical mentors supporting LBS AI Lab teams";
const academicLead = {
  id: "/mentors/#academic-lead-kostis-christodoulou",
  name: "Kostis Christodoulou",
  role: "Academic lead",
  focus:
    "Academic direction for the Lab, connecting participant teams with rigorous AI, analytics, decision-making, and product learning",
  profileUrl:
    "https://www.london.edu/faculty-and-research/faculty-profiles/k/kostis-christodoulou",
  image: "/mentors/kostis-christodoulou.jpg",
};
const mentorPersonId = (id: string) => `/mentors/#mentor-${id}`;
const jsonLd = [
  ...pageJsonLd({
    title: pageTitle,
    description: pageDescription,
    path: "/mentors/",
    breadcrumbs: [
      { name: "LBS AI Lab", path: "/" },
      { name: "Mentors", path: "/mentors/" },
    ],
  }),
  itemListJsonLd({
    name: "LBS AI Lab mentors",
    description: pageDescription,
    items: [
      {
        id: academicLead.id,
        name: academicLead.name,
        url: academicLead.id,
        type: "Person",
        description: academicLead.role,
        image: academicLead.image,
      },
      ...mentors.map((mentor) => ({
        id: mentorPersonId(mentor.data.id),
        name: mentor.data.name,
        url: mentorPersonId(mentor.data.id),
        type: "Person",
        description: mentor.data.mentorType ?? mentor.data.role,
        image: mentor.data.image,
      })),
    ],
  }),
  personJsonLd({
    id: academicLead.id,
    name: academicLead.name,
    description: academicLead.focus,
    image: academicLead.image,
    jobTitle: academicLead.role,
    sameAs: academicLead.profileUrl,
    url: academicLead.profileUrl,
  }),
  ...mentors.map((mentor) =>
    personJsonLd({
      id: mentorPersonId(mentor.data.id),
      name: mentor.data.name,
      description: mentor.data.focus,
      image: mentor.data.image,
      jobTitle: mentor.data.mentorType ?? mentor.data.role,
      sameAs: mentor.data.linkedinUrl,
      url: mentorPersonId(mentor.data.id),
    }),
  ),
];
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <section class="page-hero">
    <div class="container hero-inner">
      <p class="eyebrow">Mentors</p>
      <h1>Guidance from product and technical mentors</h1>
      <p class="lede">
        LBS AI Lab mentors help teams define problems, make product decisions,
        build with AI-assisted tools, evaluate outputs, and iterate toward
        useful products
      </p>
      <div class="hero-actions">
        <Button href={MENTOR_APPLICATION_URL} variant="red" size="lg">
          Apply to mentor
        </Button>
        <Button href="/batches/spring-2026/" variant="ghost" size="lg">
          View Spring 2026 Batch
        </Button>
      </div>
    </div>
  </section>

  <section class="section academic-section">
    <div class="container">
      <p class="eyebrow">Academic lead</p>
      <h2>Academic lead</h2>
      <DirectorCard />
    </div>
  </section>

  <section class="section section-warm mentors-section">
    <div class="container section-intro">
      <p class="eyebrow">Mentors</p>
      <h2>Mentors</h2>
      <p>
        Teams are supported by product and technical mentors through build
        sessions, product reviews, implementation guidance, and feedback cycles
      </p>
    </div>
    <div class="container mentor-list">
      <MentorGrid mentors={mentors} />
    </div>
  </section>

  <section class="section mentorship-cta">
    <div class="container cta-inner">
      <div>
        <p class="eyebrow">Mentor a future batch</p>
        <h2>Mentor a future batch</h2>
        <p>
          LBS AI Lab welcomes product, technical, and industry mentors who can
          help teams shape better AI products, navigate adoption, and build with
          confidence
        </p>
      </div>
      <Button href={MENTOR_APPLICATION_URL} variant="secondary">
        Apply to mentor
      </Button>
    </div>
  </section>

  <nav class="bottom-links" aria-label="Mentor page links">
    <div class="container">
      <a href="/batches/spring-2026/">View Spring 2026 Batch</a>
      <a href="/apply/">Join the next batch</a>
    </div>
  </nav>
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-lbs-blue);
    color: var(--color-white);
    padding-block: clamp(52px, 7vw, 92px);
  }

  .hero-inner {
    max-width: 940px;
  }

  :global(.page-hero .eyebrow) {
    color: rgba(255, 255, 255, 0.82);
  }

  h1 {
    color: var(--color-white);
    margin: 20px 0;
  }

  .lede {
    color: rgba(255, 255, 255, 0.78);
    max-width: 820px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .academic-section h2,
  .section-intro h2,
  .cta-inner h2 {
    color: var(--color-lbs-blue);
    margin: 12px 0 24px;
  }

  .section-intro p:not(.eyebrow),
  .cta-inner p:not(.eyebrow) {
    color: var(--color-ink-soft);
    font-size: var(--step-1);
    max-width: 820px;
  }

  .mentor-list {
    margin-top: 30px;
  }

  .mentorship-cta {
    background: var(--color-white);
    border-top: 1px solid var(--color-border);
  }

  .cta-inner {
    align-items: center;
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .bottom-links {
    background: var(--color-warm-white);
    border-top: 1px solid var(--color-border);
    padding-block: 20px;
  }

  .bottom-links .container {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 22px;
  }

  .bottom-links a {
    color: var(--color-lbs-blue);
    font-size: var(--step--1);
    font-weight: 850;
    text-decoration: none;
  }

  .bottom-links a::after {
    color: var(--color-lbs-red);
    content: " ->";
  }

  @media (max-width: 760px) {
    .cta-inner {
      grid-template-columns: 1fr;
    }

    .cta-inner :global(.button) {
      justify-self: start;
    }
  }
</style>
