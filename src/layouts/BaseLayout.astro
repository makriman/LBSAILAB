---
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import SkipLink from "@components/layout/SkipLink.astro";
import interLatinFont from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";
import sourceSerifLatin600Font from "@fontsource/source-serif-4/files/source-serif-4-latin-600-normal.woff2?url";
import "@styles/global.css";
import { defaultDescription, SITE_NAME, SITE_URL } from "@utils/site";
import {
  DEFAULT_OG_IMAGE,
  DEFAULT_OG_IMAGE_ALT,
  DEFAULT_ROBOTS,
  OG_IMAGE_HEIGHT,
  OG_IMAGE_TYPE,
  OG_IMAGE_WIDTH,
  organizationJsonLd,
  SEO_UPDATED_AT_ISO,
  websiteJsonLd,
} from "@utils/seo";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  imageHeight?: number;
  imageType?: string;
  imageWidth?: number;
  noindex?: boolean;
  preloadImage?: string;
  preloadImageSizes?: string;
  preloadImageSrcset?: string;
  preloadImageType?: string;
  robots?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = `${SITE_NAME} | Helping leaders become AI builders`,
  description = defaultDescription,
  image = DEFAULT_OG_IMAGE,
  imageAlt = DEFAULT_OG_IMAGE_ALT,
  imageHeight = OG_IMAGE_HEIGHT,
  imageType = OG_IMAGE_TYPE,
  imageWidth = OG_IMAGE_WIDTH,
  noindex = false,
  preloadImage,
  preloadImageSizes,
  preloadImageSrcset,
  preloadImageType,
  robots = DEFAULT_ROBOTS,
  jsonLd,
} = Astro.props;

const canonical = new URL(
  Astro.url.pathname,
  Astro.site ?? SITE_URL,
).toString();
const ogImage = new URL(image, Astro.site ?? SITE_URL).toString();
const preloadImageUrl = preloadImage
  ? new URL(preloadImage, Astro.site ?? SITE_URL).toString()
  : undefined;
const pageTitle = title.includes(SITE_NAME) ? title : `${title} | ${SITE_NAME}`;
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const siteJsonLdItems = noindex ? [] : [organizationJsonLd(), websiteJsonLd()];
const allJsonLdItems = [...siteJsonLdItems, ...jsonLdItems];
const robotsContent = noindex ? "noindex,nofollow" : robots;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const bingSiteVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="application-name" content={SITE_NAME} />
    <meta name="apple-mobile-web-app-title" content={SITE_NAME} />
    {
      googleSiteVerification && (
        <meta
          name="google-site-verification"
          content={googleSiteVerification}
        />
      )
    }
    {
      bingSiteVerification && (
        <meta name="msvalidate.01" content={bingSiteVerification} />
      )
    }
    <meta name="theme-color" content="#17145f" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en-gb" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link
      rel="preload"
      as="font"
      href={interLatinFont}
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      href={sourceSerifLatin600Font}
      type="font/woff2"
      crossorigin
    />
    <link
      rel="alternate"
      type="application/atom+xml"
      title={`${SITE_NAME} feed`}
      href={new URL("/feed.xml", Astro.site ?? SITE_URL).toString()}
    />
    {
      preloadImageUrl && (
        <link
          rel="preload"
          as="image"
          href={preloadImageUrl}
          type={preloadImageType}
          imagesrcset={preloadImageSrcset}
          imagesizes={preloadImageSizes}
        />
      )
    }
    <link rel="shortcut icon" href="/favicon/favicon.ico" type="image/x-icon" />
    <link rel="icon" href="/favicon/favicon.ico" type="image/x-icon" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon/favicon-16x16.png"
    />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:width" content={String(imageWidth)} />
    <meta property="og:image:height" content={String(imageHeight)} />
    <meta property="og:image:type" content={imageType} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:updated_time" content={SEO_UPDATED_AT_ISO} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />
    {
      allJsonLdItems.map((item) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(item)}
        />
      ))
    }
  </head>
  <body>
    <SkipLink />
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script is:inline data-vitals-monitor>
      (() => {
        if (!("PerformanceObserver" in window) || !("navigator" in window)) {
          return;
        }

        const endpoint = "/api/vitals";
        const metrics = new Map();
        const observers = [];
        let sent = false;
        const connection =
          navigator.connection ||
          navigator.mozConnection ||
          navigator.webkitConnection;

        const remember = (name, value) => {
          if (!Number.isFinite(value) || value < 0) return;
          metrics.set(name, Math.round(value * 1000) / 1000);
        };

        const viewportClass = () => {
          const width = Math.max(
            document.documentElement?.clientWidth || 0,
            window.innerWidth || 0,
          );

          if (width < 768) return "mobile";
          if (width < 1024) return "tablet";
          return "desktop";
        };

        const observe = (options, each) => {
          try {
            const observer = new PerformanceObserver((list) => {
              list.getEntries().forEach(each);
            });
            observer.observe(options);
            observers.push(observer);
          } catch {
            // Older browsers simply skip unsupported web-vital observers.
          }
        };

        const navigationEntry =
          performance.getEntriesByType?.("navigation")?.[0];

        if (navigationEntry) {
          remember("TTFB", navigationEntry.responseStart);
        }

        observe({ type: "paint", buffered: true }, (entry) => {
          if (entry.name === "first-contentful-paint") {
            remember("FCP", entry.startTime);
          }
        });

        observe({ type: "largest-contentful-paint", buffered: true }, (entry) =>
          remember("LCP", entry.startTime),
        );

        let cumulativeLayoutShift = 0;
        observe({ type: "layout-shift", buffered: true }, (entry) => {
          if (!entry.hadRecentInput) {
            cumulativeLayoutShift += entry.value;
            remember("CLS", cumulativeLayoutShift);
          }
        });

        observe(
          { type: "event", buffered: true, durationThreshold: 40 },
          (entry) => {
            if (entry.interactionId) {
              remember(
                "INP",
                Math.max(metrics.get("INP") || 0, entry.duration || 0),
              );
            }
          },
        );

        const flush = () => {
          if (sent || !metrics.size) return;
          sent = true;
          observers.forEach((observer) => observer.disconnect());

          const body = JSON.stringify({
            path: window.location.pathname,
            connectionType: connection?.effectiveType || "unknown",
            navigationType: navigationEntry?.type || "navigate",
            saveData: Boolean(connection?.saveData),
            viewport: viewportClass(),
            visibilityState: document.visibilityState,
            metrics: [...metrics].map(([name, value]) => ({ name, value })),
          });
          const blob = new Blob([body], { type: "application/json" });

          if (navigator.sendBeacon?.(endpoint, blob)) return;

          fetch(endpoint, {
            body,
            credentials: "omit",
            headers: { "Content-Type": "application/json" },
            keepalive: true,
            method: "POST",
          }).catch(() => {});
        };

        document.addEventListener(
          "visibilitychange",
          () => {
            if (document.visibilityState === "hidden") flush();
          },
          { once: true },
        );
        window.addEventListener("pagehide", flush, { once: true });
      })();
    </script>
  </body>
</html>
